<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fitsSystemWindows="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvDashboard"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/inter_bold"
            android:text="@string/dashboard_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            style="@style/screen_title"/>

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tháng 3/2026"
            android:textColor="#4C6FFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:padding="8dp"
            android:background="?attr/selectableItemBackground"
            app:drawableEndCompat="@android:drawable/arrow_down_float"
            android:drawablePadding="8dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvDashboard" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cardBalance"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/tvDate"
            style="@style/main_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/brand_primary"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_main_card_title_total"
                    style="@style/main_card_title"/>

                <TextView
                    android:id="@+id/total_money_amount"
                    style="@style/main_money_amount"
                    android:text="0 VNĐ" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    android:baselineAligned="false"
                    android:weightSum="2">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:text="↗ Expenses"
                            style="@style/main_card_left_label"/>

                        <TextView
                            android:id="@+id/expenses_money_amount"
                            style="@style/main_card_left_money_amount"
                            android:text="0 VNĐ"  />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:orientation="vertical">

                        <TextView
                            android:text="↘ Income"
                            style="@style/main_card_right_label" />

                        <TextView
                            android:id="@+id/income_money_amount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/main_card_right_money_amount"
                            android:text="0 VNĐ"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <com.github.mikephil.charting.charts.PieChart
            android:id="@+id/pieChart"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/cardBalance" />

        <TextView
            android:id="@+id/tvRecentTransactions"
            android:layout_marginTop="24dp"
            android:textSize="18sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/pieChart"
            android:text="@string/dashboard_recent_transactions"
            style="@style/screen_title"/>

        <TextView
            android:id="@+id/tvSeeAll"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="See All"
            android:textColor="#4C6FFF"
            android:textSize="14sp"
            android:padding="8dp"
            app:layout_constraintBottom_toBottomOf="@id/tvRecentTransactions"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvRecentTransactions" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvRecentTransactions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/tvRecentTransactions"
            tools:itemCount="4"
            tools:listitem="@layout/item_transaction" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>