<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/bg_search"
    android:layout_gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginBottom="15dp"
        android:text="Thêm/sửa danh mục"
        android:textColor="#000000"
        android:textSize="20sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="10dp">
        <ImageView
            android:id="@+id/imgSelectedIcon"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@android:drawable/ic_menu_gallery"
            android:background="@drawable/bg_circle_button"
            android:padding="12dp"/>
    </LinearLayout>
    <LinearLayout
        android:layout_width="200dp"
        android:layout_height="40dp"
        android:layout_gravity="center"
        android:layout_marginTop="15dp"
        android:background="@drawable/bg_search"
        android:orientation="horizontal"
        android:weightSum="2">

        <TextView
            android:id="@+id/btnTabChi"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="CHI"
            android:textColor="#888888"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnTabThu"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="THU"
            android:textColor="#888888"
            android:textStyle="bold" />
    </LinearLayout>
    <EditText
        android:id="@+id/edtCategoryName"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Tên danh mục..."
        android:textStyle="italic"
        android:paddingStart="10dp"
        android:background="@android:drawable/edit_text"
        android:layout_marginTop="10dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Icon:"
        android:layout_marginTop="15dp"
        android:textStyle="italic"/>

    <GridView
        android:id="@+id/gridIconPicker"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:numColumns="5"
        android:verticalSpacing="5dp"
        android:horizontalSpacing="5dp"
        android:scrollbars="vertical"
        android:layout_marginTop="10dp"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Color:"
        android:layout_marginTop="15dp"
        android:textStyle="italic"/>
    <GridView
        android:id="@+id/gridColorPicker"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:numColumns="5"
        android:verticalSpacing="5dp"
        android:horizontalSpacing="5dp"
        android:scrollbars="vertical"
        android:layout_marginTop="10dp"/>

    <Button
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="LƯU"
        android:layout_marginTop="20dp"
        android:backgroundTint="#000000"
        android:textColor="#FFFFFF"
        android:textStyle="bold"/>
</LinearLayout>