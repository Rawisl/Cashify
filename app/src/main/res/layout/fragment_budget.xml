<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:fitsSystemWindows="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvTitleBudget"
            android:text="@string/budget_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            style="@style/screen_title"/>

        <TextView
            android:id="@+id/tvSubTitle"
            android:text="@string/budget_subtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTitleBudget"
            style="@style/screen_subtitle"/>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardMaster"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvSubTitle">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/brand_primary"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    style="@style/budget_main_card_title"
                    android:text="@string/budget_main_card_title_monthly" />

                <TextView
                    android:id="@+id/tvMasterLimit"
                    style="@style/main_money_amount"
                    android:text="500.000.000 VNĐ" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="start"
                        android:orientation="vertical"
                        android:paddingEnd="8dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="4dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <!--                            Dùng thì chèn icon vào, không thì thôi xóa đi-->
                            <!--                            <ImageView-->
                            <!--                                android:layout_width="12dp"-->
                            <!--                                android:layout_height="12dp"-->
                            <!--                                android:src="...icon images..."-->
                            <!--                                app:tint="#E0E0E0"-->
                            <!--                                android:layout_marginEnd="4dp"/>-->

                            <TextView
                                style="@style/main_card_left_label"
                                android:text="@string/budget_label_spent" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvMasterSpent"
                            style="@style/main_card_left_money_amount"
                            android:text="999.999.999 VNĐ" />
                    </LinearLayout>


                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:orientation="vertical"
                        android:paddingStart="8dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="4dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                style="@style/main_card_right_label"
                                android:text="@string/budget_label_remaining" />

                            <!--                            <ImageView-->
                            <!--                                android:layout_width="12dp"-->
                            <!--                                android:layout_height="12dp"-->
                            <!--                                android:src="...icon image..."-->
                            <!--                                app:tint="#E0E0E0"-->
                            <!--                                android:layout_marginStart="4dp"/>-->
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvMasterRemaining"
                            style="@style/main_card_right_money_amount"
                            android:text="999.999.999VNĐ" />
                    </LinearLayout>

                </LinearLayout>

                <ProgressBar
                    android:id="@+id/pbMaster"
                    android:progress="36"
                    android:progressTint="@color/cat_pastel_green"
                    android:layout_marginTop="10dp"
                    style="@style/item_budget_progress_bar"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tvCategoryLabel"
            android:layout_marginTop="28dp"
            android:text="Category Budgets"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardMaster"
            android:textSize="16sp"
            style="@style/screen_title"/>

        <ImageButton
            android:id="@+id/btnAddBudget"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:contentDescription="Add new budget"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_input_add"
            app:tint="#4C6FFF"
            app:layout_constraintBottom_toBottomOf="@id/tvCategoryLabel"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvCategoryLabel" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvCategoryBudgets"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:nestedScrollingEnabled="false"
            app:layout_constraintTop_toBottomOf="@id/tvCategoryLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:listitem="@layout/item_budget"
            tools:itemCount="3"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="#F0F3FF"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:layout_constraintTop_toBottomOf="@id/rvCategoryBudgets"
            app:layout_constraintBottom_toBottomOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/budget_tips"
                    android:fontFamily="@font/inter_bold"
                    android:textColor="@color/tips_text_color"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>