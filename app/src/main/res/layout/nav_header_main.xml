<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/headerProfileLayout"
    android:layout_width="match_parent"
    android:layout_height="180dp"
    android:background="@drawable/bg_nav_header"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:gravity="bottom"
    android:orientation="vertical"
    android:padding="15dp">

    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/imgAvatarHeader"
        android:layout_width="64dp"
        android:layout_height="64dp"
        app:civ_border_width="1dp"
        app:civ_border_color="@color/bg_main"
        android:src="@mipmap/ic_launcher" />

    <TextView
        android:id="@+id/tvNameHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="testname"
        android:textColor="@android:color/white"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvEmailHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="testmail@gmail.com"
        android:textColor="#CCCCCC"
        android:textSize="14sp" />
</LinearLayout>