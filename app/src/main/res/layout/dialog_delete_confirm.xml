<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="@drawable/bg_popup_notif"
        android:elevation="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_percent="0.85">

        <TextView
            style="@style/btn_item_title"
            android:text="Delete Transaction"
            android:textSize="20sp"
            android:textColor="@color/brand_primary"
            android:layout_marginBottom="12dp"/>

        <TextView
            style="@style/btn_item_description"
            android:layout_width="match_parent"
            android:text="Are you sure you want to delete this transaction? This action cannot be undone."
            android:lineSpacingExtra="4dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:layout_marginTop="24dp"> <Button
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="Cancel"
            android:textAllCaps="false"
            android:fontFamily="@font/inter_bold"
            android:textColor="@color/black"
            android:backgroundTint="@color/white"
            app:backgroundTint="@null"/>

            <Button
                android:id="@+id/btnConfirmDelete"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="Delete"
                android:textAllCaps="false"
                android:fontFamily="@font/inter_bold"
                android:textColor="@color/white"
                android:backgroundTint="@color/status_red"
                app:cornerRadius="12dp"/>

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>