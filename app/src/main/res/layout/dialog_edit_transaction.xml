<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="@drawable/bg_popup_notif"
        app:layout_constraintTop_toTopOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp">
            <TextView
                style="@style/btn_item_title"
                android:text="Edit Transaction"
                android:textSize="20sp" />
            <ImageView
                android:id="@+id/btnClose"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentEnd="true"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="@color/item_description" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@color/tab_active_bg"
            android:padding="4dp"
            android:orientation="horizontal">
            <Button
                android:id="@+id/btnTabExpense"
                style="@style/btn_category_type"
                android:text="Expense"/>
            <Button
                android:id="@+id/btnTabIncome"
                style="@style/btn_category_type"
                android:text="Income"
                android:textColor="@color/item_title"
                android:backgroundTint="@android:color/transparent" />
        </LinearLayout>

        <TextView style="@style/btn_item_description" android:text="Amount" android:layout_marginTop="16dp"/>
        <EditText
            android:id="@+id/editAmount"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="$ 0"
            android:inputType="numberDecimal"
            android:paddingHorizontal="12dp"
            android:background="@drawable/bg_search"
            android:layout_marginTop="8dp"/>

        <TextView style="@style/btn_item_description" android:text="Category" android:layout_marginTop="16dp"/>
        <Spinner
            android:id="@+id/spCategory"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_search"
            android:layout_marginTop="8dp"
            android:paddingHorizontal="12dp"/>

        <TextView style="@style/btn_item_description" android:text="Description" android:layout_marginTop="16dp"/>
        <EditText
            android:id="@+id/editNote"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Note..."
            android:paddingHorizontal="12dp"
            android:background="@drawable/bg_search"
            android:layout_marginTop="8dp"/>

        <Button
            android:id="@+id/btnUpdate"
            style="@style/btn_bottom"
            android:text="Update Expense"
            android:backgroundTint="@color/status_red"
            android:layout_marginTop="32dp"/>

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>