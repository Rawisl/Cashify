<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <ImageView
                android:id="@+id/btnBack"
                style="@style/btn_back_icon"
                android:layout_width="32dp"
                android:layout_height="32dp" />

            <TextView
                style="@style/screen_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="ALL TRANSACTIONS" />
        </LinearLayout>

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_search"
            android:drawableStart="@android:drawable/ic_menu_search"
            android:drawablePadding="12dp"
            android:hint="Search transactions..."
            android:paddingHorizontal="16dp"
            android:textSize="14sp"
            android:fontFamily="@font/inter_regular" />

        <LinearLayout
            style="@style/filter_tab_container">

            <TextView
                android:id="@+id/filterAll"
                style="@style/filter_tab_item.Active"
                android:text="All" />

            <TextView
                android:id="@+id/filterIncome"
                style="@style/filter_tab_item.Inactive"
                android:text="Income" />

            <TextView
                android:id="@+id/filterExpense"
                style="@style/filter_tab_item.Inactive"
                android:text="Expense" />

        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="16dp">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvHistory"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:overScrollMode="never" />

            <LinearLayout
                android:id="@+id/layoutEmpty"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="32dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    android:alpha="0.5"
                    android:src="@drawable/ic_empty"
                    app:tint="@color/brand_primary" />

                <TextView
                    style="@style/empty_state_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="No transaction yet"
                    android:textAlignment="center" />

                <TextView
                    style="@style/empty_state_description"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Start add transactions to manage finance effectively."
                    android:textAlignment="center" />

            </LinearLayout>
        </FrameLayout>
    </LinearLayout>
</FrameLayout>