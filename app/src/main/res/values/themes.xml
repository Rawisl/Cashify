<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Cashify" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:windowActivityTransitions">true</item>
        <item name="android:windowSharedElementEnterTransition">@android:transition/move</item>
        <item name="android:windowSharedElementExitTransition">@android:transition/move</item>
    </style>

    <style name="Theme.Cashify" parent="Base.Theme.Cashify" />

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_logo_splash</item>
        <item name="postSplashScreenTheme">@style/Theme.Cashify</item>

    </style>


    <style name="circle">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!--Chỉ dùng đơn vị sp cho định dạng style text với mục đích ng dùng có thể phóng to, thu nhỏ cỡ chữ-->
    <style name="square_rounded">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">10dp</item>
    </style>

    <style name="screen_title">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">28sp</item>
        <item name="android:fontFamily">@font/inter_bold</item>
        <item name="android:textColor">@color/screen_title</item>
        <item name="android:textStyle">bold</item>
        <item name="android:layout_marginBottom">4dp</item>
    </style>

    <style name="screen_subtitle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">@font/inter_regular</item>
        <item name="android:textColor">@color/screen_subtitle</item>
        <item name="android:layout_marginBottom">24dp</item>
    </style>

    <style name="section_header">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">@font/inter_semibold</item>
        <item name="android:textColor">@color/section_header</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="cardview_buttons">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginLeft">16dp</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:layout_marginRight">16dp</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0.5dp</item>
        <item name="cardMaxElevation">2dp</item>
    </style>

    <style name="buttons_layout">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="android:focusable">true</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="btn_component_layout">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:padding">16dp</item>
    </style>

    <style name="btn_main_icon">
        <item name="android:layout_width">48dp</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:layout_gravity">center</item>
        <item name="contentPadding">10dp</item>
        <item name="shapeAppearanceOverlay">@style/circle</item>
    </style>

    <style name="btn_text_layout">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">16dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="btn_item_title">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/item_title</item>
        <item name="android:fontFamily">@font/inter_semibold</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="btn_item_description">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/item_description</item>
        <item name="android:fontFamily">@font/inter_regular</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="item_budget_title">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/item_title</item>
        <item name="android:fontFamily">@font/inter_bold</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="item_budget_money_amount">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/item_description</item>
        <item name="android:fontFamily">@font/outfit_semibold</item>
        <item name="android:textSize">13sp</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
    </style>

    <style name="item_budget_layout">
        <item name="android:layout_width">35dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_marginStart">0dp</item>
        <item name="android:layout_weight">0</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="item_budget_percent">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/item_title</item>
        <item name="android:fontFamily">@font/inter_semibold</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="item_budget_edit">
        <item name="android:layout_width">20dp</item>
        <item name="android:layout_height">20dp</item>
        <item name="android:layout_marginTop">4dp</item>
        <item name="android:src">@android:drawable/ic_menu_edit</item>
        <item name="tint">@color/btn_disabled_text</item>
    </style>

    <!--Cho cái style này kế thừa lại style có sẵn của progressbar-->
    <style name="item_budget_progress_bar" parent="Widget.AppCompat.ProgressBar.Horizontal">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:maxHeight">8dp</item>
        <item name="android:minHeight">8dp</item>
        <item name="android:progressDrawable">@drawable/bg_progress_rounded</item>
        <item name="android:max">100</item>
    </style>


    <style name="btn_next_icon">
        <item name="android:layout_width">24dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">0</item>
        <item name="srcCompat">@drawable/ic_angle_right_next</item>
        <item name="tint">@color/material_dynamic_neutral50</item>
    </style>

    <style name="btn_back_icon">
        <item name="android:layout_width">45dp</item>
        <item name="android:layout_height">45dp</item>
        <item name="android:padding">4dp</item>
        <item name="srcCompat">@drawable/ic_arrow_left_back</item>
        <item name="tint">@color/icon_inactive</item>
        <item name="shapeAppearanceOverlay">@style/circle</item>
        <item name="android:layout_gravity">left</item>
        <item name="contentPadding">7dp</item>
    </style>

    <style name="btn_bottom">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:layout_marginTop">24dp</item>
        <item name="android:backgroundTint">@color/brand_primary</item>
        <item name="android:fontFamily">@font/inter_bold</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">24sp</item>
        <item name="cornerRadius">16dp</item>
    </style>

    <style name="btn_category_type">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:fontFamily">@font/inter_bold</item>
        <item name="android:textSize">12sp</item>
        <item name="cornerRadius">16dp</item>
        <item name="textAllCaps">true</item>
    </style>


    <style name="popup_category_icon">
        <item name="android:layout_width">80dp</item>
        <item name="android:layout_height">80dp</item>
        <item name="android:layout_gravity">center</item>
        <item name="android:layout_marginTop">20dp</item>
        <item name="contentPadding">10dp</item>
        <item name="shapeAppearanceOverlay">@style/square_rounded</item>
    </style>

    <style name="popup_category_title">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_gravity">left</item>
        <item name="android:textColor">@color/screen_title</item>
        <item name="android:fontFamily">@font/inter_bold</item>
        <item name="android:layout_marginLeft">10dp</item>
        <item name="android:textSize">25sp</item>
    </style>

    <style name="popup_category_recycler">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">200dp</item>
    </style>

    <style name="main_card_title">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:fontFamily">@font/inter_regular</item>
        <item name="android:textColor">@color/bg_main</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="main_card_left_label">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:fontFamily">@font/inter_medium</item>
        <item name="android:textColor">@color/cat_pastel_coral</item>
        <item name="android:textSize">12sp</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="main_card_right_label">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:fontFamily">@font/inter_medium</item>
        <item name="android:textColor">@color/cat_pastel_green</item>
        <item name="android:textSize">12sp</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="main_card_left_money_amount">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:fontFamily">@font/outfit_bold</item>
        <item name="android:textColor">@color/cat_pastel_coral</item>
        <item name="android:textSize">16sp</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
        <item name="android:textAlignment">viewStart</item>
    </style>

    <style name="main_card_right_money_amount">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:fontFamily">@font/outfit_bold</item>
        <item name="android:textColor">@color/cat_pastel_green</item>
        <item name="android:textSize">16sp</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
        <item name="android:textAlignment">viewEnd</item>
    </style>

    <style name="main_money_amount">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">0dp</item>
        <item name="android:textColor">@color/bg_main</item>
        <item name="android:fontFamily">@font/outfit_bold</item>
        <item name="android:textSize">32sp</item>
    </style>

    <style name="main_card">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">1dp</item>
    </style>

    <style name="buttons_divider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">0.7dp</item>
        <item name="android:background">@color/cardview_divider</item>
    </style>

    <style name="numpad_key">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">72dp</item>
        <item name="layout_columnWeight">1</item>
        <item name="android:layout_margin">6dp</item>
        <item name="android:background">@drawable/bg_numpad_key</item>
        <item name="android:gravity">center</item>
        <item name="android:fontFamily">@font/outfit_bold</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/brand_primary</item>
    </style>


    <style name="float_btn_add" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@color/brand_primary</item>
        <item name="tint">@color/bg_main</item>
        <item name="elevation">0.5dp</item>
        <item name="hoveredFocusedTranslationZ">1dp</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="fabCustomSize">56dp</item>
        <item name="maxImageSize">32dp</item>
    </style>

    <style name="filter_tab_container">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:layout_marginTop">16dp</item>
    </style>

    <style name="filter_tab_item">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingHorizontal">20dp</item>
        <item name="android:paddingVertical">8dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">@font/inter_medium</item>
        <item name="android:gravity">center</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <style name="filter_tab_item.Active">
        <item name="android:background">@drawable/bg_filter_active</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:fontFamily">@font/inter_bold</item>
    </style>

    <style name="filter_tab_item.Inactive">
        <item name="android:background">@drawable/bg_filter_inactive</item>
        <item name="android:textColor">@color/item_title</item>
        <item name="android:layout_marginStart">8dp</item>
    </style>

    <style name="empty_state_title">
        <item name="android:textColor">@color/item_title</item>
        <item name="android:fontFamily">@font/inter_bold</item>
        <item name="android:textSize">18sp</item>
    </style>

    <style name="empty_state_description">
        <item name="android:textColor">@color/item_description</item>
        <item name="android:fontFamily">@font/inter_regular</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="pickdate_cardview">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:foreground">?attr/selectableItemBackground</item>
        <item name="cardBackgroundColor">@color/brand_primary</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0.5dp</item>
    </style>
</resources>