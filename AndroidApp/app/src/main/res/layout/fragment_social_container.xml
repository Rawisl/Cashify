<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F8">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/social_inner_nav_host"
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="96dp"
        app:defaultNavHost="false"
        app:navGraph="@navigation/social_nav_graph" />

    <LinearLayout
        android:id="@+id/bottom_navigation_social"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_gravity="bottom"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_bottom_nav"
        android:clipToOutline="true"
        android:elevation="8dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:paddingVertical="6dp"
        app:elevation="8dp">

        <LinearLayout
            android:id="@+id/navSocialNewsfeed"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:minHeight="52dp"
            android:orientation="vertical"
            android:paddingTop="3dp"
            android:paddingBottom="2dp">

            <ImageView
                android:id="@+id/imgSocialNewsfeed"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_home_regular"
                app:tint="#1A237E" />

            <TextView
                android:id="@+id/txtSocialNewsfeed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:fontFamily="@font/inter_bold"
                android:includeFontPadding="false"
                android:text="@string/feed"
                android:textColor="#1A237E"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navSocialProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:minHeight="52dp"
            android:orientation="vertical"
            android:paddingTop="3dp"
            android:paddingBottom="2dp">

            <ImageView
                android:id="@+id/imgSocialProfile"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_profile_regular"
                app:tint="#1A237E" />

            <TextView
                android:id="@+id/txtSocialProfile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:fontFamily="@font/inter_bold"
                android:includeFontPadding="false"
                android:text="@string/profile"
                android:textColor="#1A237E"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
