<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_budget_screen">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/social_inner_nav_host"
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="96dp"
        app:defaultNavHost="false"
        app:navGraph="@navigation/social_nav_graph" />

    <FrameLayout
        android:id="@+id/bottom_navigation_social_container"
        android:layout_width="match_parent"
        android:layout_height="@dimen/bottom_nav_social_height"
        android:layout_gravity="bottom"
        android:layout_marginHorizontal="@dimen/bottom_nav_horizontal_margin"
        android:layout_marginBottom="@dimen/bottom_nav_system_margin"
        android:clipChildren="false"
        android:clipToPadding="false">

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottom_navigation_social"
            style="@style/CashifyBottomNavigation"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:background="@drawable/bg_bottom_nav"
            app:itemIconTint="@color/nav_color_selector"
            app:itemTextAppearanceActive="@style/BottomNavWorkspaceLabelActive"
            app:itemTextAppearanceInactive="@style/BottomNavWorkspaceLabelInactive"
            app:itemTextColor="@color/nav_color_selector"
            app:labelVisibilityMode="unlabeled"
            app:menu="@menu/bottom_nav_social_menu" />
    </FrameLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
