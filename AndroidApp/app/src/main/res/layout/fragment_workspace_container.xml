<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_budget_screen">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/workspace_inner_nav_host"
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        app:defaultNavHost="false"
        app:navGraph="@navigation/workspace_nav_graph" />

    <!-- Thanh Nav Quỹ chung -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation_workspace"
        style="@style/CashifyBottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="@dimen/bottom_nav_height"
        android:layout_gravity="bottom"
        android:layout_marginHorizontal="@dimen/bottom_nav_workspace_horizontal_margin"
        android:layout_marginBottom="@dimen/bottom_nav_system_margin"
        android:background="@drawable/bg_bottom_nav"
        android:elevation="@dimen/bottom_nav_center_button_elevation"
        app:menu="@menu/bottom_nav_workspace_menu"
        app:itemIconTint="@color/nav_color_selector"
        app:itemTextAppearanceActive="@style/BottomNavWorkspaceLabelActive"
        app:itemTextAppearanceInactive="@style/BottomNavWorkspaceLabelInactive"
        app:itemTextColor="@color/nav_color_selector"
        app:labelVisibilityMode="unlabeled" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddWorkspaceTransaction"
        style="@style/float_btn_add"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="150dp"
        app:layout_behavior=".utils.FabScaleBehavior"
        app:srcCompat="@drawable/ic_add_transaction" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
