<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="#FFFDF7"
    app:cardCornerRadius="22dp"
    app:cardElevation="4dp"
    app:strokeColor="#D4A857"
    app:strokeWidth="1.5dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_milestone_premium_card"
        android:clipChildren="true"
        android:clipToOutline="true"
        android:clipToPadding="true">

        <View
            android:layout_width="82dp"
            android:layout_height="82dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="-32dp"
            android:layout_marginEnd="-22dp"
            android:alpha="0.78"
            android:background="@drawable/bg_milestone_corner_glow_gold" />

        <View
            android:id="@+id/viewMilestoneShine"
            android:layout_width="400dp"
            android:layout_height="560dp"
            android:layout_gravity="bottom|start"
            android:layout_marginStart="-64dp"
            android:layout_marginBottom="-290dp"
            android:alpha="0"
            android:background="@drawable/bg_milestone_gold_shine"
            android:clickable="false"
            android:focusable="false"
            android:importantForAccessibility="no"
            android:rotation="34" />

        <TextView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="top|start"
            android:layout_marginStart="10dp"
            android:layout_marginTop="8dp"
            android:alpha="0.55"
            android:fontFamily="@font/inter_bold"
            android:gravity="center"
            android:text="@string/diamond_sign"
            android:textColor="#D4A857"
            android:textSize="17sp" />

        <TextView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="14dp"
            android:layout_marginEnd="58dp"
            android:alpha="0.58"
            android:fontFamily="@font/inter_bold"
            android:gravity="center"
            android:text="@string/diamond_sign"
            android:textColor="#E8C675"
            android:textSize="16sp" />

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_gravity="bottom|start"
            android:layout_marginStart="26dp"
            android:layout_marginBottom="34dp"
            android:background="@drawable/bg_milestone_dot_gold" />

        <View
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:layout_gravity="center_vertical|end"
            android:layout_marginEnd="18dp"
            android:alpha="0.72"
            android:background="@drawable/bg_milestone_dot_peach" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="14dp"
            android:paddingEnd="16dp"
            android:paddingBottom="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp">

                    <TextView
                        android:id="@+id/txtMilestoneAvatar"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center"
                        android:fontFamily="@font/inter_bold"
                        android:gravity="center"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        tools:background="@drawable/bg_feed_avatar"
                        tools:text="@string/avatar_username" />

                    <com.example.cashify.ui.common.AvatarImageView
                        android:id="@+id/imgMilestoneAvatar"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:scaleType="centerCrop"
                        android:visibility="gone" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txtMilestoneUserName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:fontFamily="@font/inter_bold"
                        android:maxLines="1"
                        android:textColor="@color/brand_primary"
                        android:textSize="15sp"
                        tools:text="@string/username" />

                    <TextView
                        android:id="@+id/txtPostTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/inter_regular"
                        android:textColor="#607D8B"
                        android:textSize="12sp"
                        tools:text="@string/time_ago" />
                </LinearLayout>

                <ImageButton
                    android:id="@+id/btnMilestoneMenu"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_social_action_soft"
                    android:contentDescription="@string/menu"
                    android:padding="9dp"
                    app:srcCompat="@drawable/ic_more_horizontal"
                    app:tint="#607D8B" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="28dp"
                        android:background="@drawable/bg_milestone_chip_gold"
                        android:fontFamily="@font/inter_bold"
                        android:gravity="center"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:text="@string/achievement"
                        android:textColor="#313B60"
                        android:textSize="11sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="28dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_milestone_ribbon_gold"
                        android:fontFamily="@font/inter_bold"
                        android:gravity="center"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:text="@string/milestone"
                        android:textColor="#8A6620"
                        android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/txtMilestoneDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/inter_regular"
                android:lineSpacingExtra="4dp"
                android:textColor="#1F2937"
                android:textSize="14sp"
                tools:text="@string/milestone_description" />

            <TextView
                android:id="@+id/txtMilestoneSeeMore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:fontFamily="@font/inter_bold"
                android:paddingVertical="5dp"
                android:textColor="#B8892B"
                android:textSize="13sp"
                android:visibility="gone"
                tools:text="@string/see_more"
                tools:visibility="visible" />

            <LinearLayout
                android:id="@+id/layoutMilestoneGoalPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_milestone_goal_panel"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/txtMilestoneIcon"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_milestone_trophy_badge"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:textColor="#B8892B"
                        android:textSize="22sp"
                        tools:text="🐝" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/txtMilestoneTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter_bold"
                            android:textColor="@color/brand_primary"
                            android:textSize="16sp"
                            tools:text="Ong chăm chỉ" />

                        <TextView
                            android:id="@+id/txtMilestoneMonth"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="@font/inter_regular"
                            android:textColor="#607D8B"
                            android:textSize="13sp"
                            tools:text="Thành tựu vĩnh viễn" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/txtMilestoneAmount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="@font/inter_bold"
                    android:textColor="#313B60"
                    android:textSize="14sp"
                    tools:text="100 Giao dịch" />

                <ProgressBar
                    android:id="@+id/pbMilestoneProgress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:layout_marginTop="10dp"
                    android:progressDrawable="@drawable/bg_milestone_progress_horizontal"
                    tools:progress="100" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="14dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/btnMilestoneLike"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_action_button"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">

                    <ImageView
                        android:id="@+id/imgLikeHeart"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_heart_outline"
                        app:tint="@color/icon_inactive" />

                    <TextView
                        android:id="@+id/tvLikeCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/zero"
                        android:textColor="@color/item_description"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnMilestoneComment"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_action_button"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_comment"
                        app:tint="@color/icon_inactive" />

                    <TextView
                        android:id="@+id/tvCommentCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/zero"
                        android:textColor="@color/item_description"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnMilestoneShare"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_action_button"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_share"
                        app:tint="@color/icon_inactive" />

                    <TextView
                        android:id="@+id/tvShareCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/share"
                        android:textColor="@color/item_description"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </FrameLayout>
</com.google.android.material.card.MaterialCardView>