<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="18dp"
    app:cardBackgroundColor="@android:color/transparent"
    app:cardCornerRadius="0dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_social_editorial_card">

        <View
            android:layout_width="112dp"
            android:layout_height="112dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="-34dp"
            android:layout_marginEnd="-28dp"
            android:background="@drawable/bg_milestone_glow" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_social_insight_navy"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="14dp">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_social_warm_chip"
                    android:padding="8dp"
                    android:src="@drawable/ic_feed_trophy"
                    app:tint="@color/brand_primary" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="11dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_bold"
                        android:text="Thành tựu mới"
                        android:textColor="@color/white"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/inter_regular"
                        android:text="Một bước tiến trong hành trình tài chính"
                        android:textColor="#F5E9D8"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:background="@drawable/bg_social_peach_chip"
                    android:fontFamily="@font/inter_bold"
                    android:gravity="center"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:text="+ XP"
                    android:textColor="#6B321D"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtMilestoneIcon"
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:background="@drawable/bg_social_peach_chip"
                    android:fontFamily="@font/outfit_bold"
                    android:gravity="center"
                    android:textColor="#6B321D"
                    android:textSize="15sp"
                    tools:text="68%" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="13dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txtMilestoneMonth"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_social_warm_chip"
                        android:fontFamily="@font/inter_bold"
                        android:paddingStart="11dp"
                        android:paddingTop="4dp"
                        android:paddingEnd="11dp"
                        android:paddingBottom="4dp"
                        android:textColor="@color/brand_primary"
                        android:textSize="11sp"
                        tools:text="Tháng 5" />

                    <TextView
                        android:id="@+id/txtMilestoneTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/outfit_bold"
                        android:textColor="@color/item_title"
                        android:textSize="20sp"
                        tools:text="Quỹ du lịch đang tăng tốc" />
                </LinearLayout>

                <ImageButton
                    android:id="@+id/btnMilestoneMenu"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:background="@drawable/bg_social_action_soft"
                    android:contentDescription="Menu"
                    android:padding="9dp"
                    app:srcCompat="@drawable/ic_more_horizontal"
                    app:tint="@color/item_description" />
            </LinearLayout>

            <TextView
                android:id="@+id/txtMilestoneDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:fontFamily="@font/inter_regular"
                android:lineSpacingExtra="4dp"
                android:textColor="@color/item_title"
                android:textSize="14sp"
                tools:text="Bạn đã vượt 68% mục tiêu cho chuyến đi Đà Lạt." />

            <TextView
                android:id="@+id/txtMilestoneSeeMore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="@font/inter_bold"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:textColor="@color/brand_primary"
                android:textSize="13sp"
                android:visibility="gone"
                tools:text="Xem thêm..."
                tools:visibility="visible" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_social_action_soft"
                android:orientation="vertical"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/inter_bold"
                        android:text="Tiến độ mục tiêu"
                        android:textColor="@color/item_description"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/txtMilestoneAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/outfit_bold"
                        android:textColor="@color/brand_primary"
                        android:textSize="16sp"
                        tools:text="6.800.000đ / 10.000.000đ" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressMilestone"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="9dp"
                    android:layout_marginTop="12dp"
                    android:max="100"
                    android:progress="68"
                    android:progressDrawable="@drawable/bg_achievement_progress"
                    tools:progress="68" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="5dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_social_warm_chip"
                    android:fontFamily="@font/inter_bold"
                    android:gravity="center"
                    android:text="Streak +7"
                    android:textColor="@color/brand_primary"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="5dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_social_warm_chip"
                    android:fontFamily="@font/inter_bold"
                    android:gravity="center"
                    android:text="Cộng đồng thích"
                    android:textColor="@color/brand_primary"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>
</com.google.android.material.card.MaterialCardView>
