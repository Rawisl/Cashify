<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="24dp"
    app:cardElevation="1dp"
    app:strokeColor="@color/cardview_divider"
    app:strokeWidth="1dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_milestone_premium_card"
        android:clipChildren="true"
        android:clipToOutline="true"
        android:clipToPadding="true">

        <View
            android:layout_width="82dp"
            android:layout_height="82dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="-32dp"
            android:layout_marginEnd="-22dp"
            android:alpha="0.78"
            android:background="@drawable/bg_milestone_corner_glow_gold" />

        <View
            android:id="@+id/viewMilestoneShine"
            android:layout_width="400dp"
            android:layout_height="560dp"
            android:layout_gravity="bottom|start"
            android:layout_marginStart="-64dp"
            android:layout_marginBottom="-290dp"
            android:alpha="0"
            android:background="@drawable/bg_milestone_gold_shine"
            android:clickable="false"
            android:focusable="false"
            android:importantForAccessibility="no"
            android:rotation="34" />

        <TextView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="top|start"
            android:layout_marginStart="10dp"
            android:layout_marginTop="8dp"
            android:alpha="0.55"
            android:fontFamily="@font/inter_bold"
            android:gravity="center"
            android:text="@string/diamond_sign"
            android:textColor="#D4A857"
            android:textSize="17sp" />

        <TextView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="14dp"
            android:layout_marginEnd="58dp"
            android:alpha="0.58"
            android:fontFamily="@font/inter_bold"
            android:gravity="center"
            android:text="@string/diamond_sign"
            android:textColor="#E8C675"
            android:textSize="16sp" />

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_gravity="bottom|start"
            android:layout_marginStart="26dp"
            android:layout_marginBottom="34dp"
            android:background="@drawable/bg_milestone_dot_gold" />

        <View
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:layout_gravity="center_vertical|end"
            android:layout_marginEnd="18dp"
            android:alpha="0.72"
            android:background="@drawable/bg_milestone_dot_peach" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="14dp"
            android:paddingEnd="16dp"
            android:paddingBottom="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp">

                    <TextView
                        android:id="@+id/txtMilestoneAvatar"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center"
                        android:fontFamily="@font/inter_bold"
                        android:gravity="center"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        tools:background="@drawable/bg_feed_avatar"
                        tools:text="@string/avatar_username" />

                    <com.example.cashify.ui.common.AvatarImageView
                        android:id="@+id/imgMilestoneAvatar"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:scaleType="centerCrop"
                        android:visibility="gone" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txtMilestoneUserName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:fontFamily="@font/inter_bold"
                        android:maxLines="1"
                        android:textColor="@color/brand_primary"
                        android:textSize="15sp"
                        tools:text="@string/username" />

                    <TextView
                        android:id="@+id/txtPostTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/inter_regular"
                        android:textColor="@color/item_description"
                        android:textSize="12sp"
                        tools:text="@string/time_ago" />
                </LinearLayout>

                <TextView
                    android:id="@+id/txtMilestoneIcon"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_milestone_trophy_badge"
                    android:drawableTop="@drawable/ic_feed_trophy"
                    android:drawableTint="#B8892B"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:paddingTop="9dp"
                    android:text="" />

                <ImageButton
                    android:id="@+id/btnMilestoneMenu"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_social_action_soft"
                    android:contentDescription="@string/menu"
                    android:padding="9dp"
                    app:srcCompat="@drawable/ic_more_horizontal"
                    app:tint="@color/item_description" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="28dp"
                        android:background="@drawable/bg_milestone_chip_gold"
                        android:fontFamily="@font/inter_bold"
                        android:gravity="center"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:text="@string/achievement"
                        android:textColor="@color/brand_primary"
                        android:textSize="11sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="28dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_milestone_ribbon_gold"
                        android:fontFamily="@font/inter_bold"
                        android:gravity="center"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:text="@string/milestone"
                        android:textColor="#8A6620"
                        android:textSize="10sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/txtMilestoneTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="9dp"
                    android:fontFamily="@font/inter_bold"
                    android:lineSpacingExtra="2dp"
                    android:maxLines="3"
                    android:textColor="@color/brand_primary"
                    android:textSize="18sp"
                    tools:text="@string/milestone_title" />
            </LinearLayout>

            <TextView
                android:id="@+id/txtMilestoneDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/inter_regular"
                android:lineSpacingExtra="6dp"
                android:textColor="@color/item_title"
                android:textSize="16sp"
                android:maxLines="5"
                android:ellipsize="end"
                tools:text="@string/milestone_description" />

            <TextView
                android:id="@+id/txtMilestoneSeeMore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/inter_semibold"
                android:paddingVertical="4dp"
                android:textColor="#B8892B"
                android:textSize="14sp"
                android:visibility="gone"
                tools:text="@string/see_more"
                tools:visibility="visible" />

            <LinearLayout
                android:id="@+id/layoutMilestoneGoalPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_milestone_goal_panel"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="12dp">

                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:background="@drawable/bg_milestone_trophy_badge"
                    android:padding="7dp"
                    android:src="@drawable/ic_feed_trophy"
                    app:tint="#B8892B" />

                <TextView
                    android:id="@+id/txtMilestoneAmount"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:fontFamily="@font/inter_bold"
                    android:maxLines="1"
                    android:textColor="@color/brand_primary"
                    android:textSize="12sp"
                    tools:text="6.800.000đ / 10.000.000đ" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvPostEngagementSummary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/inter_regular"
                    android:text="@string/like_comment"
                    android:textColor="@color/item_description"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvMilestoneShareSummary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter_regular"
                    android:text="@string/share_state"
                    android:textColor="@color/item_description"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Instagram/Threads-style action row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="4dp"
                android:paddingEnd="4dp">

                <LinearLayout
                    android:id="@+id/btnMilestoneLike"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="8dp"
                    android:paddingEnd="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless">

                    <ImageView
                        android:id="@+id/imgLikeHeart"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_feed_like"
                        app:tint="@color/icon_inactive"
                        android:contentDescription="@string/like" />

                    <TextView
                        android:id="@+id/tvLikeLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:fontFamily="@font/inter_medium"
                        android:textColor="@color/item_description"
                        android:textSize="13sp"
                        android:text="@string/like" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnMilestoneComment"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="8dp"
                    android:paddingEnd="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_feed_comment"
                        app:tint="@color/icon_inactive"
                        android:contentDescription="@string/comment" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:fontFamily="@font/inter_medium"
                        android:textColor="@color/item_description"
                        android:textSize="13sp"
                        android:text="@string/comment" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnMilestoneShare"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="8dp"
                    android:paddingEnd="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_feed_share"
                        app:tint="@color/icon_inactive"
                        android:contentDescription="@string/share" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:fontFamily="@font/inter_medium"
                        android:textColor="@color/item_description"
                        android:textSize="13sp"
                        android:text="@string/share" />
                </LinearLayout>


            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutMilestoneInlineComments"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical"
                android:visibility="gone"
                tools:visibility="visible">

                <LinearLayout
                    android:id="@+id/layoutMilestoneCommentPreviewList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <TextView
                    android:id="@+id/btnMilestoneViewAllComments"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:fontFamily="@font/inter_bold"
                    android:paddingVertical="6dp"
                    android:textColor="@color/brand_primary"
                    android:textSize="13sp"
                    android:visibility="gone"
                    tools:text="View all comments (8)"
                    tools:visibility="visible" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_social_action_soft"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingEnd="8dp">

                    <EditText
                        android:id="@+id/editMilestoneInlineComment"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:fontFamily="@font/inter_regular"
                        android:hint="Write a comment..."
                        android:inputType="textCapSentences|textMultiLine"
                        android:maxLines="2"
                        android:textColor="@color/item_title"
                        android:textColorHint="@color/item_description"
                        android:textSize="13sp" />

                    <ImageButton
                        android:id="@+id/btnMilestoneSendInlineComment"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/comment"
                        android:padding="9dp"
                        app:srcCompat="@drawable/ic_send"
                        app:tint="@color/brand_primary" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>
</com.google.android.material.card.MaterialCardView>
