<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F0F2F8">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbarFriends"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="@drawable/bg_toolbar_rounded"
                app:navigationIcon="@drawable/ic_menu_padded"
                app:navigationIconTint="@color/white">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="@string/social_profile_friends"
                    android:textAppearance="@style/ToolbarTitleFont"
                    android:textColor="@color/white" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="end|center_vertical"
                    android:layout_marginEnd="8dp"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:layoutDirection="rtl">

                    <ImageButton
                        android:id="@+id/btnMessages"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/message"
                        android:padding="10dp"
                        app:srcCompat="@drawable/ic_messages_regular"
                        app:tint="@color/white" />

                    <FrameLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layoutDirection="ltr">

                        <ImageButton
                            android:id="@+id/btnNotifications"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="@string/notification"
                            android:padding="10dp"
                            android:scaleType="center"
                            android:src="@drawable/ic_notification_regular"
                            app:tint="@color/white" />

                        <TextView
                            android:id="@+id/tvNotificationBadge"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="top|end"
                            android:layout_marginTop="4dp"
                            android:layout_marginEnd="3dp"
                            android:background="@drawable/bg_badge_red"
                            android:gravity="center"
                            android:text="@string/one"
                            android:textColor="@color/white"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:visibility="gone" />
                    </FrameLayout>
                </LinearLayout>
            </com.google.android.material.appbar.MaterialToolbar>

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:fillViewport="true"
                android:paddingBottom="96dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="18dp"
                    android:paddingTop="18dp"
                    android:paddingEnd="18dp"
                    android:paddingBottom="24dp">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardSearch"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        app:cardBackgroundColor="#FFFFFF"
                        app:cardCornerRadius="25dp"
                        app:cardElevation="0dp">

                        <EditText
                            android:id="@+id/edtSearch"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@null"
                            android:drawableStart="@android:drawable/ic_menu_search"
                            android:drawablePadding="10dp"
                            android:hint="@string/searching_friend"
                            android:imeOptions="actionSearch"
                            android:inputType="text"
                            android:paddingStart="20dp"
                            android:paddingEnd="18dp"
                            android:singleLine="true"
                            android:textColor="#1A237E"
                            android:textColorHint="#8A95A7"
                            android:textSize="14sp" />
                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:id="@+id/cardRequests"
                        android:layout_width="match_parent"
                        android:layout_height="72dp"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_creator_panel"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:background="@drawable/bg_social_metric_chip"
                            android:padding="10dp"
                            android:src="@drawable/ic_request"
                            app:tint="#1A237E" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/inter_bold"
                                android:text="@string/request"
                                android:textColor="#1A237E"
                                android:textSize="16sp" />

                            <TextView
                                android:id="@+id/tvRequestsSummary"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:fontFamily="@font/inter_regular"
                                android:text="@string/waiting_request"
                                android:textColor="#607D8B"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="34dp"
                            android:background="@drawable/bg_tag_blue"
                            android:fontFamily="@font/inter_bold"
                            android:gravity="center"
                            android:minWidth="76dp"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:text="@string/open"
                            android:textColor="#1A237E"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/inter_bold"
                            android:text="@string/friend_suggestion"
                            android:textColor="#1A237E"
                            android:textSize="20sp" />

                        <TextView
                            android:id="@+id/tvSuggestionCount"
                            android:visibility="gone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter_medium"
                            android:textColor="#607D8B"
                            android:textSize="13sp"
                            tools:text="@string/friend_number" />
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvSuggestions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:clipToPadding="false"
                        android:orientation="horizontal"
                        android:overScrollMode="never"
                        android:paddingEnd="10dp"
                        tools:itemCount="3"
                        tools:listitem="@layout/item_friend_suggestion" />

                    <TextView
                        android:id="@+id/tvSuggestionsEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_creator_panel"
                        android:fontFamily="@font/inter_regular"
                        android:gravity="center"
                        android:padding="18dp"
                        android:text="@string/no_friend_suggestion"
                        android:textColor="#607D8B"
                        android:textSize="13sp"
                        android:visibility="gone" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="26dp"
                        android:fontFamily="@font/inter_bold"
                        android:text="@string/connect"
                        android:textColor="#1A237E"
                        android:textSize="20sp" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvFriends"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:clipToPadding="false"
                        android:nestedScrollingEnabled="false"
                        tools:itemCount="4"
                        tools:listitem="@layout/item_friend" />

                    <TextView
                        android:id="@+id/tvFriendsEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_creator_panel"
                        android:fontFamily="@font/inter_regular"
                        android:gravity="center"
                        android:padding="18dp"
                        android:text="@string/no_connect"
                        android:textColor="#607D8B"
                        android:textSize="13sp"
                        android:visibility="gone" />
                </LinearLayout>
            </androidx.core.widget.NestedScrollView>
        </LinearLayout>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabAddFriend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="22dp"
            android:layout_marginBottom="24dp"
            android:contentDescription="@string/add_friend"
            android:tint="@color/white"
            app:backgroundTint="#1A237E"
            app:elevation="6dp"
            app:srcCompat="@android:drawable/ic_input_add"
            app:tint="@null" />
    </FrameLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:headerLayout="@layout/nav_header_main"
        app:menu="@menu/nav_menu_sidebar" />

</androidx.drawerlayout.widget.DrawerLayout>
