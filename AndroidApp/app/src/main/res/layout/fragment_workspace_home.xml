<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_budget_screen"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbarWorkspaceDetail"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="@drawable/bg_workspace_header_light"
            app:navigationIcon="@drawable/ic_menu_padded"
            app:navigationIconTint="@color/brand_primary"
            app:titleCentered="true"
            app:titleTextAppearance="@style/MyCustomToolbarTitle"
            app:titleTextColor="@color/brand_primary">

            <FrameLayout
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="12dp">

                <ImageButton
                    android:id="@+id/btnWorkspaceNotifications"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="11dp"
                    android:scaleType="center"
                    android:src="@drawable/ic_notification_regular"
                    app:tint="@color/brand_primary" />

                <TextView
                    android:id="@+id/tvNotificationBadge"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="8dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_badge_red"
                    android:gravity="center"
                    android:text="@string/one"
                    android:textColor="@color/white"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </FrameLayout>
        </com.google.android.material.appbar.MaterialToolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <ProgressBar
        android:id="@+id/progressBarWorkspace"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_budget_screen"
        android:clipToPadding="false"
        android:paddingBottom="104dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="16dp"
            android:paddingEnd="20dp"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/tvDashboard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/outfit_bold"
                android:text="@string/groups_title"
                android:textColor="@color/screen_title"
                android:textSize="28sp" />

            <TextView
                android:id="@+id/tvDashboard_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/inter_regular"
                android:lineSpacingExtra="2dp"
                android:text="@string/groups_subtitle"
                android:textColor="@color/item_description"
                android:textSize="14sp" />

            <androidx.cardview.widget.CardView
                android:id="@+id/cardWorkspaceBalance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_budget_master_card"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:paddingEnd="12dp">

                            <TextView
                                style="@style/main_card_title"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/group_balance_label" />

                            <TextView
                                android:id="@+id/tvWorkspaceNameCard"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="5dp"
                                android:ellipsize="end"
                                android:fontFamily="@font/inter_bold"
                                android:maxLines="1"
                                android:textColor="#DDE6FF"
                                android:textSize="13sp"
                                tools:text="May Rent Group" />
                        </LinearLayout>

                        <ImageView
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:alpha="0.95"
                            android:background="@drawable/bg_budget_master_glass"
                            android:importantForAccessibility="no"
                            android:padding="10dp"
                            android:src="@drawable/ic_group_regular"
                            app:tint="@color/white" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvWorkspaceBalance"
                        style="@style/main_money_amount"
                        android:layout_marginTop="10dp"
                        android:text="@string/zero_vnd" />

                    <TextView
                        android:id="@+id/tvWorkspaceActivitySummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/inter_medium"
                        android:text="@string/group_no_activity"
                        android:textColor="#BFD0FF"
                        android:textSize="12.5sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:baselineAligned="false"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_budget_master_glass"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/inter_extrabold"
                                android:text="@string/budget_label_expense"
                                android:textColor="#9fadd4"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvWorkspaceExpense"
                                style="@style/main_card_left_money_amount"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:text="@string/zero_vnd" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_budget_master_glass"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/inter_extrabold"
                                android:text="@string/budget_label_income"
                                android:textColor="#9fadd4"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvWorkspaceIncome"
                                style="@style/main_card_right_money_amount"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:ellipsize="end"
                                android:gravity="start"
                                android:maxLines="1"
                                android:text="@string/zero_vnd" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvWorkspaceMemberCount"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_budget_master_glass"
                        android:fontFamily="@font/inter_bold"
                        android:gravity="center"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:text="@string/group_members_zero"
                        android:textColor="@color/white"
                        android:textSize="12sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="24dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvMembersTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/outfit_bold"
                    android:text="@string/members"
                    android:textColor="@color/screen_title"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/tvAddMember"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_budget_pill"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="@font/inter_bold"
                    android:gravity="center"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="@string/plus_add"
                    android:textColor="@color/brand_primary"
                    android:textSize="14sp" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvWorkspaceMembers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_member_avatar" />

            <TextView
                android:id="@+id/tvRecentTransactionsTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:fontFamily="@font/outfit_bold"
                android:text="@string/transactions"
                android:textColor="@color/screen_title"
                android:textSize="20sp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvWorkspaceTransactions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_transaction" />

            <LinearLayout
                android:id="@+id/layoutWorkspaceEmptyTransactions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_budget_glass_card"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="24dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:alpha="0.9"
                    android:importantForAccessibility="no"
                    android:padding="8dp"
                    android:src="@drawable/ic_group_regular"
                    app:tint="@color/brand_primary" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/inter_bold"
                    android:gravity="center"
                    android:text="@string/group_empty_activity_title"
                    android:textColor="@color/item_title"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/inter_regular"
                    android:gravity="center"
                    android:lineSpacingExtra="2dp"
                    android:text="@string/group_empty_activity_desc"
                    android:textColor="@color/item_description"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
