<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_budget_screen"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingTop="34dp"
        android:paddingEnd="22dp"
        android:paddingBottom="28dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="start"
            android:background="@drawable/bg_login_heart_bubble"
            android:contentDescription="@string/action_back"
            android:padding="11dp"
            android:src="@drawable/ic_arrow_left_back"
            app:tint="@color/brand_primary" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="214dp"
            android:layout_marginTop="8dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <View
                android:layout_width="118dp"
                android:layout_height="118dp"
                android:layout_gravity="bottom|start"
                android:layout_marginStart="-36dp"
                android:layout_marginBottom="-14dp"
                android:alpha="0.72"
                android:background="@drawable/bg_login_cloud" />

            <View
                android:layout_width="130dp"
                android:layout_height="130dp"
                android:layout_gravity="bottom|end"
                android:layout_marginEnd="-48dp"
                android:layout_marginBottom="-20dp"
                android:alpha="0.65"
                android:background="@drawable/bg_login_cloud" />

            <TextView
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_gravity="top|start"
                android:layout_marginStart="38dp"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/outfit_bold"
                android:gravity="center"
                android:text="@string/decor_star"
                android:textColor="@color/accent_gold"
                android:textSize="28sp" />

            <TextView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_gravity="center|end"
                android:layout_marginEnd="22dp"
                android:background="@drawable/bg_login_coin"
                android:fontFamily="@font/outfit_bold"
                android:gravity="center"
                android:text="@string/dollar_sign"
                android:textColor="@color/white"
                android:textSize="18sp" />

            <ImageView
                android:layout_width="194dp"
                android:layout_height="194dp"
                android:layout_gravity="center"
                android:adjustViewBounds="true"
                android:contentDescription="@string/login_mascot_desc"
                android:scaleType="fitCenter"
                android:src="@drawable/cashy_mascot" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/outfit_bold"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="@string/auth_reset_password_title"
            android:textColor="@color/brand_primary"
            android:textSize="28sp" />

        <TextView
            android:id="@+id/tvDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:fontFamily="@font/inter_medium"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:text="@string/auth_reset_password_desc"
            android:textColor="@color/screen_subtitle"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:background="@drawable/bg_login_card"
            android:elevation="8dp"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingTop="24dp"
            android:paddingEnd="22dp"
            android:paddingBottom="22dp">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutEmailReset"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/auth_email"
                app:boxBackgroundColor="@color/white"
                app:boxCornerRadiusBottomEnd="18dp"
                app:boxCornerRadiusBottomStart="18dp"
                app:boxCornerRadiusTopEnd="18dp"
                app:boxCornerRadiusTopStart="18dp"
                app:boxStrokeColor="@color/auth_input_stroke"
                app:boxStrokeErrorColor="@color/status_red"
                app:boxStrokeWidth="1.5dp"
                app:boxStrokeWidthFocused="2dp"
                app:hintTextColor="@color/screen_subtitle">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtEmailReset"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:fontFamily="@font/inter_medium"
                    android:inputType="textEmailAddress"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="@color/brand_primary"
                    android:textColorHint="@color/screen_subtitle"
                    android:textSize="14sp"
                    tools:text="@string/cashy_gmail" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/inter_regular"
                android:lineSpacingExtra="3dp"
                android:text="@string/auth_reset_password_hint"
                android:textColor="@color/screen_subtitle"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSendReset"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/inter_bold"
                android:text="@string/auth_send_instructions"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
                app:backgroundTint="@color/brand_primary"
                app:cornerRadius="28dp"
                app:elevation="3dp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
