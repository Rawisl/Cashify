<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_budget_screen"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <include layout="@layout/include_personal_workspace_header" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/bg_budget_screen"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/settings_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingTop="16dp"
            android:paddingEnd="22dp"
            android:paddingBottom="132dp">

            <TextView
                android:id="@+id/tv_Account"
                style="@style/section_header"
                android:text="@string/settings_section_account" />

            <androidx.cardview.widget.CardView
                android:id="@+id/cv_account"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:cardBackgroundColor="#F1F3F9"
                app:cardCornerRadius="24dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:id="@+id/btn_security"
                    style="@style/btn_component_layout"
                    android:minHeight="78dp">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/iv_ic_security"
                        style="@style/btn_main_icon"
                        android:background="@color/icon_setting_background"
                        app:srcCompat="@drawable/ic_settings_password_key"
                        app:tint="@color/brand_primary" />

                    <LinearLayout style="@style/btn_text_layout">

                        <TextView
                            android:id="@+id/tv_security"
                            style="@style/btn_item_title"
                            android:text="@string/settings_item_security" />

                        <TextView
                            android:id="@+id/tv_secur_subtitle"
                            style="@style/btn_item_description"
                            android:layout_marginTop="3dp"
                            android:text="@string/settings_item_security_desc" />
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/iv_ic_next"
                        style="@style/btn_next_icon"
                        android:contentDescription="@string/action_next" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tv_Preferences"
                style="@style/section_header"
                android:layout_marginTop="24dp"
                android:text="@string/settings_section_preferences" />

            <androidx.cardview.widget.CardView
                android:id="@+id/cv_preferences"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:cardBackgroundColor="#F1F3F9"
                app:cardCornerRadius="24dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/btn_categories"
                        style="@style/btn_component_layout"
                        android:minHeight="78dp">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/iv_ic_category"
                            style="@style/btn_main_icon"
                            android:background="@color/icon_setting_background"
                            app:srcCompat="@drawable/ic_settings_category"
                            app:tint="@color/brand_primary" />

                        <LinearLayout style="@style/btn_text_layout">

                            <TextView
                                android:id="@+id/tv_categories"
                                style="@style/btn_item_title"
                                android:text="@string/settings_item_category" />

                            <TextView
                                android:id="@+id/tv_category"
                                style="@style/btn_item_description"
                                android:layout_marginTop="3dp"
                                android:text="@string/settings_item_category_desc" />
                        </LinearLayout>

                        <ImageView
                            style="@style/btn_next_icon"
                            android:contentDescription="@string/action_next" />
                    </LinearLayout>

                    <View style="@style/buttons_divider" />

                    <LinearLayout
                        android:id="@+id/btn_notification"
                        style="@style/btn_component_layout"
                        android:minHeight="78dp">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/iv_ic_notification"
                            style="@style/btn_main_icon"
                            android:background="@color/icon_setting_background"
                            app:srcCompat="@drawable/ic_notification_regular"
                            app:tint="@color/brand_primary" />

                        <LinearLayout style="@style/btn_text_layout">

                            <TextView
                                android:id="@+id/tv_notification"
                                style="@style/btn_item_title"
                                android:text="@string/settings_item_notifications" />

                            <TextView
                                android:id="@+id/tv_noti"
                                style="@style/btn_item_description"
                                android:layout_marginTop="3dp"
                                android:text="@string/settings_item_notifications_desc" />
                        </LinearLayout>

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/toggle_notification"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical" />
                    </LinearLayout>

                    <View style="@style/buttons_divider" />

                    <LinearLayout
                        android:id="@+id/btn_language"
                        style="@style/btn_component_layout"
                        android:minHeight="78dp">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/iv_ic_language"
                            style="@style/btn_main_icon"
                            android:background="@color/icon_setting_background"
                            app:srcCompat="@drawable/ic_language_exchange_regular"
                            app:tint="@color/brand_primary" />

                        <LinearLayout style="@style/btn_text_layout">

                            <TextView
                                android:id="@+id/tv_language"
                                style="@style/btn_item_title"
                                android:text="@string/settings_item_language" />

                            <TextView
                                android:id="@+id/tv_lang"
                                style="@style/btn_item_description"
                                android:layout_marginTop="3dp"
                                android:text="@string/settings_item_language_desc" />
                        </LinearLayout>

                        <ImageView
                            android:id="@+id/iv_language_arrow"
                            style="@style/btn_next_icon"
                            android:contentDescription="@string/action_next" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layout_language_options"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="80dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="14dp"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/option_language_english"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_input_fields"
                            android:fontFamily="@font/inter_semibold"
                            android:gravity="center_vertical"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:text="@string/settings_item_language_desc"
                            android:textColor="@color/brand_primary"
                            android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tv_Reset"
                style="@style/section_header"
                android:layout_marginTop="24dp"
                android:text="@string/settings_section_reset" />

            <androidx.cardview.widget.CardView
                android:id="@+id/cv_reset_transaction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:cardBackgroundColor="#F1F3F9"
                app:cardCornerRadius="24dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:id="@+id/btn_reset_transaction"
                    style="@style/btn_component_layout"
                    android:minHeight="78dp">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/iv_ic_reset_transaction"
                        style="@style/btn_main_icon"
                        android:background="@color/status_background_red"
                        app:srcCompat="@drawable/ic_settings_reset"
                        app:tint="@color/status_red" />

                    <LinearLayout style="@style/btn_text_layout">

                        <TextView
                            android:id="@+id/tv_reset_transaction"
                            style="@style/btn_item_title"
                            android:text="@string/settings_item_reset_transaction" />

                        <TextView
                            android:id="@+id/tv_reset_transaction_desc"
                            style="@style/btn_item_description"
                            android:layout_marginTop="3dp"
                            android:text="@string/settings_item_reset_transaction_desc" />
                    </LinearLayout>

                    <ImageView
                        style="@style/btn_next_icon"
                        android:contentDescription="@string/action_next" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tv_Other"
                style="@style/section_header"
                android:layout_marginTop="24dp"
                android:text="@string/settings_section_other" />

            <androidx.cardview.widget.CardView
                android:id="@+id/cv_other"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:cardBackgroundColor="#F1F3F9"
                app:cardCornerRadius="24dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:id="@+id/btn_logout"
                    style="@style/btn_component_layout"
                    android:minHeight="78dp">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/iv_ic_logout"
                        style="@style/btn_main_icon"
                        android:background="@color/status_background_red"
                        app:srcCompat="@drawable/ic_settings_logout"
                        app:tint="@color/status_red" />

                    <LinearLayout style="@style/btn_text_layout">

                        <TextView
                            android:id="@+id/tv_logout"
                            style="@style/btn_item_title"
                            android:text="@string/settings_item_logout" />

                        <TextView
                            android:id="@+id/tv_logout_subtitle"
                            style="@style/btn_item_description"
                            android:layout_marginTop="3dp"
                            android:text="@string/settings_item_logout_desc" />
                    </LinearLayout>

                    <ImageView
                        style="@style/btn_next_icon"
                        android:contentDescription="@string/action_next" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
