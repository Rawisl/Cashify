<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardBackgroundColor="@android:color/transparent"
    app:cardCornerRadius="0dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_brutal_card_white"
        android:orientation="vertical"
        android:paddingStart="17dp"
        android:paddingTop="17dp"
        android:paddingEnd="23dp"
        android:paddingBottom="23dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="52dp"
                android:layout_height="52dp">

                <TextView
                    android:id="@+id/txtAvatar"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:fontFamily="@font/inter_bold"
                    android:gravity="center"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    tools:background="@drawable/bg_feed_avatar"
                    tools:text="MA" />

                <ImageView
                    android:id="@+id/imgAvatar"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:scaleType="centerCrop"
                    android:visibility="gone" />

                <View
                    android:layout_width="13dp"
                    android:layout_height="13dp"
                    android:layout_gravity="bottom|end"
                    android:background="@drawable/bg_online_dot" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtUserName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:fontFamily="@font/inter_bold"
                    android:maxLines="1"
                    android:textColor="@color/item_title"
                    android:textSize="15sp"
                    tools:text="Minh Anh" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/txtPostTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_regular"
                        android:textColor="@color/item_description"
                        android:textSize="12sp"
                        tools:text="5 phút trước" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_post_tag"
                        android:fontFamily="@font/inter_semibold"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="3dp"
                        android:text="Public"
                        android:textColor="@color/brand_primary"
                        android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnPostMenu"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_icon_soft_button"
                android:contentDescription="Menu"
                android:padding="9dp"
                app:srcCompat="@drawable/ic_more_horizontal"
                app:tint="@color/item_description" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtPostContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:fontFamily="@font/inter_regular"
            android:lineSpacingExtra="4dp"
            android:textColor="@color/item_title"
            android:textSize="14sp"
            tools:text="Vừa hoàn thành mục tiêu tiết kiệm tuần này. Cảm giác rất đã!" />

        <TextView
            android:id="@+id/txtSeeMore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="7dp"
            android:fontFamily="@font/inter_semibold"
            android:paddingVertical="4dp"
            android:textColor="@color/brand_primary"
            android:textSize="13sp"
            android:visibility="gone"
            tools:text="Xem thêm..."
            tools:visibility="visible" />

        <FrameLayout
            android:id="@+id/postImagePlaceholder"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="15dp"
            android:background="@drawable/bg_feed_image_placeholder"
            android:visibility="gone"
            tools:visibility="visible">

            <!-- ← ẢNH THẬT — Glide load vào đây -->
            <ImageView
                android:id="@+id/imgPostImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@null"
                android:scaleType="centerCrop"
                android:visibility="gone" />

            <!-- Decorator chỉ hiện khi chưa có URL (skeleton look) -->
            <View
                android:id="@+id/decorCircle"
                android:layout_width="86dp"
                android:layout_height="86dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="-18dp"
                android:layout_marginEnd="-12dp"
                android:background="@drawable/bg_feed_header_circle_soft" />

            <ImageView
                android:id="@+id/decorIcon"
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_feed_header_button"
                android:contentDescription="@null"
                android:padding="15dp"
                android:src="@drawable/ic_post_image"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/decorCaption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:layout_marginStart="16dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_image_caption"
                android:fontFamily="@font/inter_semibold"
                android:paddingHorizontal="12dp"
                android:paddingVertical="7dp"
                android:text="Goal snapshot"
                android:textColor="@color/black"
                android:textSize="12sp" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/inter_medium"
                android:text="0 likes · 0 comments"
                android:textColor="@color/item_description"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_medium"
                android:text="0 shares"
                android:textColor="@color/item_description"
                android:textSize="12sp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:background="@color/black" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnLike"
                style="@style/feed_action_text"
                android:drawableStart="@drawable/ic_feed_like"
                android:text="Like" />

            <TextView
                android:id="@+id/btnComment"
                style="@style/feed_action_text"
                android:drawableStart="@drawable/ic_feed_comment"
                android:text="Comment" />

            <TextView
                android:id="@+id/btnShare"
                style="@style/feed_action_text"
                android:drawableStart="@drawable/ic_feed_share"
                android:text="Share" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
