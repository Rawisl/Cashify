<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="22dp"
    app:cardElevation="3dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="14dp"
        android:paddingEnd="16dp"
        android:paddingBottom="14dp">

        <FrameLayout
            android:id="@+id/postImagePlaceholder"
            android:layout_width="match_parent"
            android:layout_height="210dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_social_story_image"
            android:visibility="gone"
            tools:visibility="visible">

            <ImageView
                android:id="@+id/imgPostImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@null"
                android:scaleType="centerCrop"
                android:visibility="gone" />

            <View
                android:id="@+id/decorCircle"
                android:layout_width="104dp"
                android:layout_height="104dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="-30dp"
                android:layout_marginEnd="-24dp"
                android:background="@drawable/bg_milestone_glow" />

            <ImageView
                android:id="@+id/decorIcon"
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_social_warm_chip"
                android:contentDescription="@null"
                android:padding="15dp"
                android:src="@drawable/ic_post_image"
                app:tint="#1A237E" />

            <TextView
                android:id="@+id/decorCaption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:layout_marginStart="14dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_social_peach_chip"
                android:fontFamily="@font/inter_bold"
                android:paddingHorizontal="12dp"
                android:paddingVertical="7dp"
                android:text="@string/cashify_story"
                android:textColor="#1A237E"
                android:textSize="11sp" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="60dp"
                android:layout_height="60dp">

                <TextView
                    android:id="@+id/txtAvatar"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_gravity="center"
                    android:fontFamily="@font/inter_bold"
                    android:gravity="center"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    tools:background="@drawable/bg_feed_avatar"
                    tools:text="MA" />

                <com.example.cashify.ui.common.AvatarImageView
                    android:id="@+id/imgAvatar"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:scaleType="centerCrop"
                    android:visibility="gone" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtUserName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:fontFamily="@font/inter_bold"
                    android:maxLines="1"
                    android:textColor="#1A237E"
                    android:textSize="16sp"
                    tools:text="Minh Anh" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/txtPostTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_regular"
                        android:textColor="#607D8B"
                        android:textSize="12sp"
                        tools:text="5 phút trước" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="24dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_social_warm_chip"
                        android:fontFamily="@font/inter_bold"
                        android:gravity="center"
                        android:paddingHorizontal="9dp"
                        android:text="@string/public_state"
                        android:textColor="#1A237E"
                        android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnPostMenu"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_social_action_soft"
                android:contentDescription="@string/menu"
                android:padding="9dp"
                app:srcCompat="@drawable/ic_more_horizontal"
                app:tint="#607D8B" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtPostContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:fontFamily="@font/inter_regular"
            android:lineSpacingExtra="4dp"
            android:textColor="#1F2937"
            android:textSize="14sp"
            tools:text="Vừa hoàn thành mục tiêu tiết kiệm tuần này. Cảm giác rất đã!" />

        <TextView
            android:id="@+id/txtSeeMore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="@font/inter_bold"
            android:paddingVertical="5dp"
            android:textColor="#1A237E"
            android:textSize="13sp"
            android:visibility="gone"
            tools:text="Xem thêm..."
            tools:visibility="visible" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/inter_regular"
                android:text="@string/like_comment"
                android:textColor="#607D8B"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_regular"
                android:text="@string/share_state"
                android:textColor="#607D8B"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnLike"
                style="@style/feed_action_text"
                android:background="@drawable/bg_social_action_soft"
                android:drawableStart="@drawable/ic_feed_like"
                android:text="@string/like" />

            <TextView
                android:id="@+id/btnComment"
                style="@style/feed_action_text"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_social_action_soft"
                android:drawableStart="@drawable/ic_feed_comment"
                android:text="@string/comment" />

            <TextView
                android:id="@+id/btnShare"
                style="@style/feed_action_text"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_social_action_soft"
                android:drawableStart="@drawable/ic_feed_share"
                android:text="@string/share" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
