<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@color/bg_main"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/add_transaction_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/action_back"
                android:padding="8dp"
                android:src="@drawable/ic_arrow_left_back"
                app:tint="@color/screen_title" />

            <TextView
                android:id="@+id/tvTitle"
                style="@style/screen_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="@string/action_add_transaction"
                android:textSize="24sp"/>
            <ImageView
                android:id="@+id/btnDelete"
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="6dp"
                android:src="@drawable/ic_trash_regular"
                app:tint="@color/status_red"
                android:visibility="gone"
                tools:visibility="visible" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:background="@drawable/bg_tab_outline"
            android:orientation="horizontal"
            android:padding="4dp"
            android:weightSum="2">

            <TextView
                android:id="@+id/tabChi"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_tab_outline"
                android:fontFamily="@font/inter_bold"
                android:gravity="center"
                android:text="@string/tab_expense"
                android:textAllCaps="true"
                android:textColor="@color/status_red"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tabThu"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:fontFamily="@font/inter_medium"
                android:gravity="center"
                android:text="@string/tab_income"
                android:textAllCaps="true"
                android:textColor="@color/item_description"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            style="@style/section_header"
            android:layout_marginTop="10dp"
            android:text="@string/trans_input_amount" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">

            <EditText
                android:id="@+id/edtAmount"
                style="@style/main_money_amount"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_centerInParent="true"
                android:background="@drawable/bg_input_fields"
                android:hint="0"
                android:inputType="numberDecimal"
                android:paddingStart="16dp"
                android:paddingEnd="60dp"
                android:textColor="@color/status_red"
                android:textSize="28sp" />
            <ImageView
                android:id="@+id/btnScan"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="10dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:padding="10dp"
                android:src="@drawable/ic_camera"
                app:tint="@color/brand_primary" />

        </RelativeLayout>

        <TextView
            style="@style/section_header"
            android:layout_marginTop="10dp"
            android:text="@string/settings_item_category" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="24dp"
            app:cardElevation="1dp">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCategories"
                android:layout_width="match_parent"
                android:layout_height="170dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="true"
                android:padding="12dp"
                android:scrollbars="vertical" />
        </androidx.cardview.widget.CardView>

        <TextView
            style="@style/section_header"
            android:layout_marginTop="10dp"
            android:text="@string/trans_description" />

        <EditText
            android:id="@+id/edtNote"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_fields"
            android:fontFamily="@font/inter_regular"
            android:hint="@string/hint_buy_something"
            android:inputType="textMultiLine|textCapSentences|textAutoCorrect"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/item_title"
            android:textSize="15sp" />

        <TextView
            style="@style/section_header"
            android:layout_marginTop="10dp"
            android:text="@string/section_date" />

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_fields"
            android:drawablePadding="10dp"
            android:fontFamily="@font/inter_medium"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="@string/trans_input_date"
            android:textColor="@color/item_title"
            app:drawableTint="@color/brand_primary" />

        <TextView
            style="@style/section_header"
            android:layout_marginTop="10dp"
            android:text="@string/section_payment" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:layout_marginTop="8dp"
            android:baselineAligned="false"
            android:orientation="horizontal"
            android:weightSum="3">

            <LinearLayout
                android:id="@+id/btnPayCash"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input_fields"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/imgCash"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="@string/method_cash"
                    android:src="@drawable/ic_cash"
                    app:tint="@color/brand_primary" />

                <TextView
                    android:id="@+id/tvCash"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/inter_medium"
                    android:text="@string/method_cash"
                    android:textColor="@color/brand_primary"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnPayCard"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginHorizontal="3dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input_fields"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/imgCard"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="@string/method_card"
                    android:src="@drawable/ic_credit_card"
                    app:tint="@color/item_description" />

                <TextView
                    android:id="@+id/tvCard"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/inter_medium"
                    android:text="@string/method_card"
                    android:textColor="@color/item_description"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnPayBank"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input_fields"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/imgBank"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="@string/method_bank"
                    android:src="@drawable/ic_bank"
                    app:tint="@color/item_description" />

                <TextView
                    android:id="@+id/tvBank"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/inter_medium"
                    android:text="@string/method_bank"
                    android:textColor="@color/item_description"
                    android:textSize="11sp" />
            </LinearLayout>

        </LinearLayout>

        <Button
            android:id="@+id/btnConfirm"
            android:layout_width="match_parent"
            android:layout_height="62dp"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="15dp"
            android:backgroundTint="@color/brand_primary"
            android:fontFamily="@font/inter_bold"
            android:text="@string/action_confirm"
            android:textColor="@color/white"
            android:textSize="16sp"
            app:cornerRadius="18dp"
            app:elevation="4dp" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>