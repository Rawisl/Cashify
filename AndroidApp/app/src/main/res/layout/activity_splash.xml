<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_budget_screen">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingEnd="32dp">

        <ImageView
            android:id="@+id/imgSplashMascot"
            android:layout_width="292dp"
            android:layout_height="218dp"
            android:adjustViewBounds="true"
            android:contentDescription="@string/splash_mascot_desc"
            android:scaleType="fitCenter"
            android:src="@drawable/cashy_running" />

        <TextView
            android:id="@+id/txtSplashLoading"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:fontFamily="@font/inter_medium"
            android:gravity="center"
            android:lineSpacingExtra="3dp"
            android:text="@string/splash_loading_default"
            android:textColor="@color/screen_subtitle"
            android:textSize="14sp" />

        <ProgressBar
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="156dp"
            android:layout_height="6dp"
            android:layout_marginTop="18dp"
            android:indeterminate="true"
            android:indeterminateDrawable="@drawable/bg_splash_progress" />
    </LinearLayout>
</FrameLayout>
