<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="16dp"
    android:paddingBottom="14dp">

    <!-- Card chính -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardComment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="1dp"
        app:cardBackgroundColor="@color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="20dp">

            <!-- Avatar -->
            <com.example.cashify.ui.common.AvatarImageView
                android:id="@+id/imgCommentAvatar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:scaleType="centerCrop"
                android:src="@drawable/bg_default_avatar_pastel" />

            <!-- Comment Content -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <!-- Username + Time + Menu -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvCommentUsername"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Username"
                        android:textColor="@color/item_title"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvCommentTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="2 hours ago"
                        android:textColor="@color/item_description"
                        android:textSize="12sp" />

                    <!-- Spacer đẩy icon sang phải -->
                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <!-- Icon 3 chấm dọc -->
                    <ImageView
                        android:id="@+id/imgCommentMenu"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_more_vert"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="6dp"
                        app:tint="@color/icon_inactive" />

                </LinearLayout>

                <!-- Nội dung comment -->
                <TextView
                    android:id="@+id/tvCommentContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="This is a comment text"
                    android:textColor="@color/item_title"
                    android:textSize="14sp"
                    android:lineSpacingExtra="2dp" />

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Like badge -->
    <LinearLayout
        android:id="@+id/layoutCommentLike"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="24dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true"
        android:background="@drawable/bg_comment_like_badge"
        android:paddingHorizontal="12dp"
        android:paddingVertical="5dp"
        android:elevation="4dp">

        <ImageView
            android:id="@+id/imgCommentLike"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_heart_outline"
            app:tint="@color/icon_inactive" />

        <TextView
            android:id="@+id/tvCommentLikeCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="0"
            android:textColor="@color/item_description"
            android:textSize="12sp" />

    </LinearLayout>

</FrameLayout>
