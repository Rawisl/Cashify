<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/ivIcon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="@string/category_choose_icon"
                android:padding="10dp"
                android:src="@android:drawable/ic_menu_agenda" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="16dp"
                android:layout_toEndOf="@id/ivIcon"
                android:orientation="vertical"
                tools:ignore="RelativeOverlap">

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter_bold"
                    android:textColor="@color/brand_primary"
                    android:textSize="20sp"
                    tools:text="Food" />

                <TextView
                    android:id="@+id/tvSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter_semibold"
                    android:textColor="@color/screen_subtitle"
                    android:textSize="12sp"
                    tools:text="Edit budget limits" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnClose"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/action_cancel"
                android:padding="12dp"
                android:scaleType="centerInside"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="#9E9E9E" />
        </RelativeLayout>

        <LinearLayout
            android:id="@+id/layoutCategorySelector"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                style="@style/section_header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/settings_item_category"
                android:textAllCaps="false"
                android:textColor="@color/item_title"
                android:textSize="14sp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCategoryPicker"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#F5F5F5"
                android:nestedScrollingEnabled="false"
                android:padding="8dp"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:spanCount="4"
                tools:listitem="@layout/item_category_picker" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvCurrentSpendingLabel"
            style="@style/section_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/budget_category_current_spending"
            android:textAllCaps="false"
            android:textColor="@color/item_title"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvCurrentSpending"
            style="@style/item_budget_money_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="0dp"
            android:textColor="#121212"
            android:textSize="24sp"
            tools:text="450.000 VND" />

        <TextView
            style="@style/section_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/budget_category_budget_amount"
            android:textAllCaps="false"
            android:textColor="@color/item_title"
            android:textSize="14sp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutInputAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:boxBackgroundColor="#FFFFFF"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusTopStart="12dp"
            app:boxStrokeColor="@color/cat_pastel_gray"
            app:hintEnabled="false"
            app:suffixText="@string/VND_currency">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edtBudgetAmount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/action_enter_amount"
                android:inputType="numberDecimal" />
        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/btnSaveBudget"
            style="@style/btn_bottom"
            android:layout_marginBottom="24dp"
            android:text="@string/action_save" />

        <Button
            android:id="@+id/btnDeleteBudget"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="24dp"
            android:fontFamily="@font/inter_bold"
            android:text="@string/action_delete"
            android:textAllCaps="false"
            android:textColor="@color/status_red"
            android:textSize="24sp"
            android:visibility="gone"
            app:cornerRadius="16dp"
            app:strokeColor="@color/status_red"
            tools:visibility="visible" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>