<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingBottom="24dp">

    <!-- Handle bar -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"
        android:background="#CCCCCC" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Share to"
        android:gravity="center"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/item_title"
        android:layout_marginBottom="24dp" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingHorizontal="16dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Zalo -->
            <LinearLayout
                android:id="@+id/btnShareZalo"
                android:layout_width="76dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:src="@drawable/ic_messages_regular"
                    android:background="@drawable/bg_circle_button"
                    android:padding="14dp"
                    app:tint="@color/brand_primary" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Zalo"
                    android:textSize="13sp"
                    android:textColor="@color/item_title"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

            <!-- Messenger -->
            <LinearLayout
                android:id="@+id/btnShareMessenger"
                android:layout_width="76dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:src="@drawable/ic_messages_solid"
                    android:background="@drawable/bg_circle_button"
                    android:padding="14dp"
                    app:tint="#0084FF" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Messenger"
                    android:textSize="13sp"
                    android:textColor="@color/item_title"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

            <!-- Facebook -->
            <LinearLayout
                android:id="@+id/btnShareFacebook"
                android:layout_width="76dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:src="@drawable/ic_group_regular"
                    android:background="@drawable/bg_circle_button"
                    android:padding="14dp"
                    app:tint="#1877F2" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Facebook"
                    android:textSize="13sp"
                    android:textColor="@color/item_title"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

            <!-- Copy Link -->
            <LinearLayout
                android:id="@+id/btnShareCopyLink"
                android:layout_width="76dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:src="@drawable/ic_other"
                    android:background="@drawable/bg_circle_button"
                    android:padding="14dp"
                    app:tint="@color/item_description" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Copy Link"
                    android:textSize="13sp"
                    android:textColor="@color/item_title"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

            <!-- More -->
            <LinearLayout
                android:id="@+id/btnShareMore"
                android:layout_width="76dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:src="@drawable/ic_more_horizontal"
                    android:background="@drawable/bg_circle_button"
                    android:padding="14dp"
                    app:tint="@color/item_title" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="More"
                    android:textSize="13sp"
                    android:textColor="@color/item_title"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

        </LinearLayout>
    </HorizontalScrollView>

</LinearLayout>
