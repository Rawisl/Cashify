<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_budget_screen"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:minHeight="640dp"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingTop="38dp"
        android:paddingEnd="22dp"
        android:paddingBottom="24dp">

        <TextView
            android:id="@+id/txtOnboardingLogo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/outfit_bold"
            android:text="cashify"
            android:textColor="#1A237E"
            android:textSize="38sp" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="310dp"
            android:layout_marginTop="14dp">

            <View
                android:layout_width="236dp"
                android:layout_height="236dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_soft_circle" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_marginStart="28dp"
                android:layout_marginTop="36dp"
                android:fontFamily="@font/outfit_bold"
                android:text="✦"
                android:textColor="#FFB36B"
                android:textSize="26sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_marginTop="52dp"
                android:layout_marginEnd="34dp"
                android:fontFamily="@font/outfit_bold"
                android:text="✦"
                android:textColor="#D4A857"
                android:textSize="20sp" />

            <TextView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_gravity="bottom|start"
                android:layout_marginStart="42dp"
                android:layout_marginBottom="52dp"
                android:background="@drawable/bg_social_warm_chip"
                android:fontFamily="@font/inter_bold"
                android:gravity="center"
                android:text="$"
                android:textColor="#D4A857"
                android:textSize="16sp" />

            <TextView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="bottom|end"
                android:layout_marginEnd="48dp"
                android:layout_marginBottom="44dp"
                android:background="@drawable/bg_social_warm_chip"
                android:fontFamily="@font/inter_bold"
                android:gravity="center"
                android:text="$"
                android:textColor="#D4A857"
                android:textSize="13sp" />

            <ImageView
                android:id="@+id/imgCashyMascot"
                android:layout_width="268dp"
                android:layout_height="268dp"
                android:layout_gravity="center"
                android:contentDescription="Cashy"
                android:scaleType="fitCenter"
                android:src="@drawable/cashy_mascot" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_onboarding_card"
            android:elevation="8dp"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/outfit_bold"
                android:gravity="center"
                android:lineSpacingExtra="2dp"
                android:text="Money feels friendlier"
                android:textColor="#1A237E"
                android:textSize="22sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/inter_regular"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:text="Track spending, savings, and daily goals."
                android:textColor="#607D8B"
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOnboardingStart"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="24dp"
                android:elevation="4dp"
                android:fontFamily="@font/inter_bold"
                android:text="Get Started"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                app:backgroundTint="#1A237E"
                app:cornerRadius="24dp" />

            <TextView
                android:id="@+id/txtOnboardingLogin"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/inter_regular"
                android:gravity="center"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="Already have an account? Sign In"
                android:textColor="#607D8B"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
