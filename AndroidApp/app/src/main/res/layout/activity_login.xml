<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_budget_screen"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingTop="48dp"
        android:paddingEnd="22dp"
        android:paddingBottom="26dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="292dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <View
                android:layout_width="106dp"
                android:layout_height="106dp"
                android:layout_gravity="bottom|start"
                android:layout_marginStart="-32dp"
                android:layout_marginBottom="2dp"
                android:alpha="0.78"
                android:background="@drawable/bg_login_cloud" />

            <View
                android:layout_width="132dp"
                android:layout_height="132dp"
                android:layout_gravity="bottom|end"
                android:layout_marginEnd="-42dp"
                android:layout_marginBottom="-18dp"
                android:alpha="0.72"
                android:background="@drawable/bg_login_cloud" />

            <TextView
                android:id="@+id/txtLoginStarOne"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="top|start"
                android:layout_marginStart="34dp"
                android:layout_marginTop="22dp"
                android:fontFamily="@font/outfit_bold"
                android:gravity="center"
                android:text="@string/diamond_sign"
                android:textColor="@color/accent_gold"
                android:textSize="32sp" />

            <TextView
                android:id="@+id/txtLoginStarTwo"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="42dp"
                android:layout_marginEnd="44dp"
                android:fontFamily="@font/outfit_bold"
                android:gravity="center"
                android:text="@string/diamond_sign"
                android:textColor="@color/accent_gold"
                android:textSize="28sp" />

            <TextView
                android:id="@+id/txtLoginHeart"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_gravity="center|end"
                android:layout_marginTop="22dp"
                android:layout_marginEnd="2dp"
                android:background="@drawable/bg_login_heart_bubble"
                android:fontFamily="@font/outfit_bold"
                android:gravity="center"
                android:text="@string/heart_sign"
                android:textColor="@color/accent_gold"
                android:textSize="27sp" />

            <TextView
                android:id="@+id/txtLoginCoinOne"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="center|start"
                android:layout_marginStart="6dp"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_login_coin"
                android:fontFamily="@font/outfit_bold"
                android:gravity="center"
                android:text="@string/dollar_sign"
                android:textColor="@color/white"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/txtLoginCoinTwo"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_gravity="bottom|end"
                android:layout_marginEnd="34dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_login_coin"
                android:fontFamily="@font/outfit_bold"
                android:gravity="center"
                android:text="@string/dollar_sign"
                android:textColor="@color/white"
                android:textSize="17sp" />

            <ImageView
                android:id="@+id/imgLoginMascot"
                android:layout_width="260dp"
                android:layout_height="252dp"
                android:layout_gravity="center"
                android:adjustViewBounds="true"
                android:contentDescription="@string/login_mascot_desc"
                android:scaleType="fitCenter"
                android:src="@drawable/cashy_mascot" />
        </FrameLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/outfit_bold"
            android:gravity="center"
            android:includeFontPadding="false"
            android:lineSpacingExtra="2dp"
            android:text="@string/auth_welcome_back"
            android:textColor="@color/brand_primary"
            android:textSize="30sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:fontFamily="@font/inter_medium"
            android:gravity="center"
            android:lineSpacingExtra="3dp"
            android:text="@string/login_soft_subtitle"
            android:textColor="@color/screen_subtitle"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_login_card"
            android:elevation="8dp"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingTop="24dp"
            android:paddingEnd="22dp"
            android:paddingBottom="20dp">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/auth_email"
                app:boxBackgroundColor="@color/white"
                app:boxCornerRadiusBottomEnd="18dp"
                app:boxCornerRadiusBottomStart="18dp"
                app:boxCornerRadiusTopEnd="18dp"
                app:boxCornerRadiusTopStart="18dp"
                app:boxStrokeColor="@color/auth_input_stroke"
                app:boxStrokeErrorColor="@color/status_red"
                app:boxStrokeWidth="1.5dp"
                app:boxStrokeWidthFocused="2dp"
                app:hintTextColor="@color/screen_subtitle">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtEmail"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:fontFamily="@font/inter_medium"
                    android:inputType="textEmailAddress"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="@color/brand_primary"
                    android:textColorHint="@color/screen_subtitle"
                    android:textSize="14sp"
                    tools:text="@string/cashy_gmail" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:hint="@string/auth_password"
                app:boxBackgroundColor="@color/white"
                app:boxCornerRadiusBottomEnd="18dp"
                app:boxCornerRadiusBottomStart="18dp"
                app:boxCornerRadiusTopEnd="18dp"
                app:boxCornerRadiusTopStart="18dp"
                app:boxStrokeColor="@color/auth_input_stroke"
                app:boxStrokeErrorColor="@color/status_red"
                app:boxStrokeWidth="1.5dp"
                app:boxStrokeWidthFocused="2dp"
                app:hintTextColor="@color/screen_subtitle"
                app:passwordToggleEnabled="true"
                app:passwordToggleTint="@color/screen_subtitle">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtPassword"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:fontFamily="@font/inter_medium"
                    android:inputType="textPassword"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="@color/brand_primary"
                    android:textColorHint="@color/screen_subtitle"
                    android:textSize="14sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/tvForgotPassword"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/inter_bold"
                android:paddingStart="10dp"
                android:paddingTop="8dp"
                android:paddingEnd="2dp"
                android:paddingBottom="8dp"
                android:text="@string/auth_forgot_password"
                android:textColor="@color/brand_primary"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/inter_bold"
                android:text="@string/auth_login"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
                app:backgroundTint="@color/brand_primary"
                app:cornerRadius="28dp"
                app:elevation="3dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center"
                android:orientation="horizontal">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/cardview_divider" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter_medium"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:text="@string/auth_or"
                    android:textColor="@color/screen_subtitle"
                    android:textSize="12sp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/cardview_divider" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGoogleLogin"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/inter_bold"
                android:text="@string/auth_sign_in_google"
                android:textAllCaps="false"
                android:textColor="@color/brand_primary"
                android:textSize="14sp"
                app:backgroundTint="@color/white"
                app:cornerRadius="26dp"
                app:strokeColor="@color/cardview_divider"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRegister"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/inter_bold"
                android:gravity="center"
                android:text="@string/auth_dont_have_account"
                android:textAllCaps="false"
                android:textColor="@color/brand_primary"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
