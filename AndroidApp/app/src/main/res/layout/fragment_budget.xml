<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_budget_screen"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <include layout="@layout/include_personal_workspace_header" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/bg_budget_screen"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingTop="16dp"
            android:paddingEnd="22dp"
            android:paddingBottom="132dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/layoutLinkedMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="0dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_budget_glass_card"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_budget_pill"
                        android:fontFamily="@font/outfit_bold"
                        android:gravity="center"
                        android:text="∞"

                        android:textColor="#1A237E"
                        android:textSize="20sp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingEnd="10dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter_bold"
                            android:text="@string/budget_linked_mode_title"
                            android:textColor="@color/item_title"
                            android:textSize="15.5sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="@font/inter_regular"
                            android:lineSpacingExtra="2dp"
                            android:text="Automatic allocation"
                            android:textColor="@color/item_description"
                            android:textSize="12.5sp" />
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/btnInfoLink"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="8dp"
                        android:src="@drawable/ic_info_blue"
                        app:tint="#1A237E" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchLinkedMode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggleGroupPeriod"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_budget_segmented_container"
                android:gravity="center"
                android:padding="4dp"
                app:checkedButton="@+id/btnMonthly"
                app:singleSelection="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnWeekly"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:fontFamily="@font/inter_bold"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="@string/tab_weekly"
                    android:textAllCaps="false"
                    android:textSize="14sp"
                    app:cornerRadius="22dp"
                    app:strokeWidth="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMonthly"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:fontFamily="@font/inter_bold"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="@string/tab_monthly"
                    android:textAllCaps="false"
                    android:textSize="14sp"
                    app:cornerRadius="22dp"
                    app:strokeWidth="0dp" />
            </com.google.android.material.button.MaterialButtonToggleGroup>

            <LinearLayout
                android:id="@+id/layoutDateSelectors"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardWeekSelector"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginEnd="10dp"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_budget_pill"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingEnd="14dp">

                        <TextView
                            android:id="@+id/tvWeek"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter_bold"
                            android:textColor="#1A237E"
                            android:textSize="13sp"
                            tools:text="@string/week" />

                        <ImageView
                            android:layout_width="15dp"
                            android:layout_height="15dp"
                            android:layout_marginStart="6dp"
                            android:importantForAccessibility="no"
                            android:src="@android:drawable/arrow_down_float"
                            app:tint="#1A237E" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardMonthSelector"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_budget_pill"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingEnd="14dp">

                        <TextView
                            android:id="@+id/tvMonth"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter_bold"
                            android:textColor="#1A237E"
                            android:textSize="13sp"
                            tools:text="@string/month" />

                        <ImageView
                            android:layout_width="15dp"
                            android:layout_height="15dp"
                            android:layout_marginStart="6dp"
                            android:importantForAccessibility="no"
                            android:src="@android:drawable/arrow_down_float"
                            app:tint="#1A237E" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardMaster"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_budget_master_card"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvMasterTitle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/inter_semibold"
                            android:text="@string/budget_main_card_title_monthly"
                            android:textColor="#BFD0FF"
                            android:letterSpacing="0.1"
                            android:textSize="13sp" />

                        <ImageView
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:alpha="0.9"
                            android:background="@drawable/bg_budget_master_glass"
                            android:importantForAccessibility="no"
                            android:padding="9dp"
                            android:src="@android:drawable/ic_menu_edit"
                            app:tint="@color/white" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvMasterLimit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="0dp"
                        android:fontFamily="@font/outfit_extrabold"
                        android:includeFontPadding="false"
                        android:text="0 VND"
                        android:textColor="@color/white"
                        android:textSize="45sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:baselineAligned="false"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_budget_master_glass"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/inter_extrabold"
                                android:text="@string/budget_label_spent"
                                android:textColor="#9fadd4"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvMasterSpent"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="5dp"
                                android:ellipsize="end"
                                android:fontFamily="@font/outfit_bold"
                                android:maxLines="1"
                                android:text="0 VND"
                                style="@style/main_card_left_money_amount"
                                android:textSize="18sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_budget_master_glass"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/inter_extrabold"
                                android:text="@string/budget_label_remaining"
                                android:textColor="#9fadd4"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvMasterRemaining"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="5dp"
                                android:ellipsize="end"
                                android:fontFamily="@font/outfit_bold"
                                android:maxLines="1"
                                android:text="0 VND"
                                style="@style/main_card_right_money_amount"
                                android:textSize="18sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:fontFamily="@font/inter_medium"
                        android:text="Usage indicator"
                        android:textColor="#BFD0FF"
                        android:textSize="12sp" />

                    <ProgressBar
                        android:id="@+id/pbMaster"
                        style="@style/item_budget_progress_bar"
                        android:layout_marginTop="8dp"
                        android:progress="0"
                        android:progressTint="#FFE7DD" />

                    <TextView
                        android:id="@+id/tvMasterAlert"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:fontFamily="@font/inter_semibold"
                        android:gravity="center"
                        android:textSize="12sp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/btnShareMilestone"
                        android:layout_width="match_parent"
                        android:layout_height="46dp"
                        android:layout_marginTop="18dp"
                        android:background="@drawable/bg_budget_share_cta"
                        android:clickable="true"
                        android:focusable="true"
                        android:fontFamily="@font/inter_bold"
                        android:gravity="center"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:text="Share Milestone"
                        android:textColor="#1A237E"
                        android:textSize="15sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_budget_tip_card"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:background="@drawable/bg_budget_glass_card"
                            android:fontFamily="@font/outfit_bold"
                            android:gravity="center"
                            android:text="!"
                            android:textColor="#1A237E"
                            android:textSize="20sp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/inter_extrabold"
                                android:text="@string/budget_tips"
                                android:textColor="#2D1600"
                                android:textSize="16sp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:fontFamily="@font/inter_semibold"
                                android:text="SMART RECOMMENDATION"
                                android:textColor="#C5823F"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:fontFamily="@font/inter_regular"
                        android:lineSpacingExtra="3dp"
                        android:text="Set category limits after your master budget to keep spending balanced and easy to scan."
                        android:textColor="@color/item_description"
                        android:textSize="13.5sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="30dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvCategoryLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/outfit_bold"
                    android:text="@string/budget_category"
                    android:textColor="@color/screen_title"
                    android:textSize="21sp" />

                <ImageButton
                    android:id="@+id/btnAddBudget"
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:background="@drawable/bg_budget_add_category_button"
                    android:contentDescription="@string/action_add_new_budget"
                    android:padding="12dp"
                    android:scaleType="centerInside"
                    android:src="@android:drawable/ic_input_add"
                    app:tint="#1A237E" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCategoryBudgets"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="-6dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="-6dp"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                tools:itemCount="5"
                tools:listitem="@layout/item_budget" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
