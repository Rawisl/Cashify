<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <include layout="@layout/include_personal_workspace_header" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/bg_main"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingTop="24dp"
            android:paddingEnd="22dp"
            android:paddingBottom="132dp">

            <TextView
                android:id="@+id/tvTitleBudget"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/outfit_bold"
                android:text="@string/nav_budget"
                android:textColor="@color/screen_title"
                android:textSize="32sp" />

            <TextView
                android:id="@+id/tvSubTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/inter_regular"
                android:text="@string/budget_subtitle"
                android:textColor="@color/screen_subtitle"
                android:textSize="14sp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/layoutLinkedMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeColor="#E5DCCE"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingEnd="12dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter_bold"
                            android:text="@string/budget_linked_mode_title"
                            android:textColor="@color/item_title"
                            android:textSize="15sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:fontFamily="@font/inter_regular"
                            android:lineSpacingExtra="2dp"
                            android:text="Connect weekly category limits with your monthly master budget."
                            android:textColor="@color/item_description"
                            android:textSize="12.5sp" />
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/btnInfoLink"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="8dp"
                        android:src="@drawable/ic_info_blue" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchLinkedMode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggleGroupPeriod"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="14dp"
                android:gravity="center"
                app:checkedButton="@+id/btnMonthly"
                app:singleSelection="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnWeekly"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:fontFamily="@font/inter_bold"
                    android:text="@string/tab_weekly"
                    android:textAllCaps="false"
                    android:textSize="14sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMonthly"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:fontFamily="@font/inter_bold"
                    android:text="@string/tab_monthly"
                    android:textAllCaps="false"
                    android:textSize="14sp" />
            </com.google.android.material.button.MaterialButtonToggleGroup>

            <LinearLayout
                android:id="@+id/layoutDateSelectors"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardWeekSelector"
                    style="@style/pickdate_cardview"
                    android:layout_marginEnd="10dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="14dp"
                        android:paddingEnd="12dp">

                        <TextView
                            android:id="@+id/tvWeek"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter_bold"
                            android:textColor="@color/white"
                            android:textSize="13sp"
                            tools:text="Week 1" />

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginStart="6dp"
                            android:importantForAccessibility="no"
                            android:src="@android:drawable/arrow_down_float"
                            app:tint="@color/white" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardMonthSelector"
                    style="@style/pickdate_cardview">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="14dp"
                        android:paddingEnd="12dp">

                        <TextView
                            android:id="@+id/tvMonth"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter_bold"
                            android:textColor="@color/white"
                            android:textSize="13sp"
                            tools:text="Month 4/2026" />

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginStart="6dp"
                            android:importantForAccessibility="no"
                            android:src="@android:drawable/arrow_down_float"
                            app:tint="@color/white" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardMaster"
                style="@style/main_card"
                android:layout_marginTop="22dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/brand_primary"
                    android:orientation="vertical"
                    android:padding="22dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvMasterTitle"
                            style="@style/main_card_title"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/budget_main_card_title_monthly" />

                        <ImageView
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:alpha="0.7"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:importantForAccessibility="no"
                            android:padding="8dp"
                            android:src="@android:drawable/ic_menu_edit"
                            app:tint="@color/bg_main" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvMasterLimit"
                        style="@style/main_money_amount"
                        android:layout_marginTop="8dp"
                        android:text="0 VND" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:baselineAligned="false"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_input_fields"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <TextView
                                style="@style/main_card_left_label"
                                android:text="@string/budget_label_spent" />

                            <TextView
                                android:id="@+id/tvMasterSpent"
                                style="@style/main_card_left_money_amount"
                                android:layout_marginTop="4dp"
                                android:text="0 VND" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_input_fields"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <TextView
                                style="@style/main_card_right_label"
                                android:text="@string/budget_label_remaining" />

                            <TextView
                                android:id="@+id/tvMasterRemaining"
                                style="@style/main_card_right_money_amount"
                                android:layout_marginTop="4dp"
                                android:text="0 VND" />
                        </LinearLayout>
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/pbMaster"
                        style="@style/item_budget_progress_bar"
                        android:layout_marginTop="18dp"
                        android:progress="0"
                        android:progressTint="@color/cat_pastel_green" />

                    <TextView
                        android:id="@+id/tvMasterAlert"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:fontFamily="@font/inter_semibold"
                        android:gravity="center"
                        android:textSize="12sp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/btnShareMilestone"
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_action_button"
                        android:clickable="true"
                        android:focusable="true"
                        android:fontFamily="@font/inter_bold"
                        android:gravity="center"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:text="Share Milestone"
                        android:textColor="@color/brand_primary"
                        android:textSize="13sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="#F0F3FF"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/bg_circle_icon"
                        android:fontFamily="@font/outfit_bold"
                        android:gravity="center"
                        android:text="💡"
                        android:textSize="18sp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter_bold"
                            android:text="@string/budget_tips"
                            android:textColor="@color/tips_text_color"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:fontFamily="@font/inter_regular"
                            android:lineSpacingExtra="2dp"
                            android:text="Set category limits after your master budget to keep spending balanced."
                            android:textColor="@color/item_description"
                            android:textSize="12.5sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="26dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvCategoryLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/outfit_bold"
                    android:text="@string/budget_category"
                    android:textColor="@color/screen_title"
                    android:textSize="20sp" />

                <ImageButton
                    android:id="@+id/btnAddBudget"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/action_add_new_budget"
                    android:padding="9dp"
                    android:scaleType="centerInside"
                    android:src="@android:drawable/ic_input_add"
                    app:tint="@color/brand_primary" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCategoryBudgets"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="-6dp"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="-6dp"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                tools:itemCount="5"
                tools:listitem="@layout/item_budget" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
