<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F8"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarRequests"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#F0F2F8"
        app:navigationIcon="@drawable/ic_arrow_left_back"
        app:navigationIconTint="#1A237E"
        app:title="@string/friend_request"
        app:titleCentered="true"
        app:titleTextColor="#1A237E" />

    <!-- Tab: Received / Sent -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_below="@id/toolbarRequests"
        android:layout_marginHorizontal="16dp"
        android:background="@drawable/bg_tab_container"
        app:tabBackground="@null"
        app:tabGravity="fill"
        app:tabMode="fixed"
        app:tabIndicatorColor="#1A237E"
        app:tabIndicatorHeight="3dp"
        app:tabSelectedTextColor="#1A237E"
        app:tabTextColor="#9E9E9E"
        app:tabTextAppearance="@style/TabTextAppearance" />

    <!-- Danh sách -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvRequests"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/tabLayout"
        android:clipToPadding="false"
        android:paddingTop="8dp"
        android:paddingBottom="16dp" />

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/layoutEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/hold_hands"
            android:textSize="48sp" />

        <TextView
            android:id="@+id/tvEmptyMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/no_requests_yet"
            android:textSize="16sp"
            android:textColor="#9E9E9E"
            android:layout_marginTop="8dp" />
    </LinearLayout>

</RelativeLayout>
