<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="172dp"
    android:layout_height="184dp"
    android:layout_marginEnd="12dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="22dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="14dp">

        <com.example.cashify.ui.common.AvatarImageView
            android:id="@+id/imgAvatar"
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:scaleType="centerCrop"
            android:src="@drawable/bg_default_avatar_pastel" />

        <TextView
            android:id="@+id/tvFriendName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:ellipsize="end"
            android:fontFamily="@font/inter_bold"
            android:gravity="center"
            android:maxLines="1"
            android:textColor="#1A237E"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:ellipsize="end"
            android:fontFamily="@font/inter_regular"
            android:gravity="center"
            android:maxLines="1"
            android:textColor="#607D8B"
            android:textSize="12sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddFriend"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="14dp"
            android:text="Kết bạn"
            android:textAllCaps="false"
            android:textSize="13sp"
            app:backgroundTint="#1A237E"
            app:cornerRadius="13dp"
            app:icon="@android:drawable/ic_input_add"
            app:iconSize="15dp"
            app:iconTint="@color/white" />

        <TextView
            android:id="@+id/tvSentRequest"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_tag_grey"
            android:fontFamily="@font/inter_bold"
            android:gravity="center"
            android:text="Đang chờ"
            android:textColor="#607D8B"
            android:textSize="13sp"
            android:visibility="gone" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
