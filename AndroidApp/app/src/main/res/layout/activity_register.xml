<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_budget_screen"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingTop="44dp"
        android:paddingEnd="22dp"
        android:paddingBottom="26dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="252dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <View
                android:layout_width="112dp"
                android:layout_height="112dp"
                android:layout_gravity="bottom|start"
                android:layout_marginStart="-38dp"
                android:layout_marginBottom="-10dp"
                android:alpha="0.72"
                android:background="@drawable/bg_login_cloud" />

            <View
                android:layout_width="132dp"
                android:layout_height="132dp"
                android:layout_gravity="bottom|end"
                android:layout_marginEnd="-48dp"
                android:layout_marginBottom="-18dp"
                android:alpha="0.65"
                android:background="@drawable/bg_login_cloud" />

            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="top|start"
                android:layout_marginStart="36dp"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/outfit_bold"
                android:gravity="center"
                android:text="@string/decor_star"
                android:textColor="@color/accent_gold"
                android:textSize="30sp" />

            <TextView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center|end"
                android:layout_marginEnd="4dp"
                android:background="@drawable/bg_login_heart_bubble"
                android:fontFamily="@font/outfit_bold"
                android:gravity="center"
                android:text="♥"
                android:textColor="@color/accent_gold"
                android:textSize="25sp" />

            <TextView
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_gravity="center|start"
                android:layout_marginStart="10dp"
                android:layout_marginTop="36dp"
                android:background="@drawable/bg_login_coin"
                android:fontFamily="@font/outfit_bold"
                android:gravity="center"
                android:text="$"
                android:textColor="@color/white"
                android:textSize="17sp" />

            <ImageView
                android:layout_width="220dp"
            android:layout_height="214dp"
                android:layout_gravity="center"
                android:adjustViewBounds="true"
                android:contentDescription="@string/login_mascot_desc"
                android:scaleType="fitCenter"
                android:src="@drawable/cashy_mascot" />
        </FrameLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/outfit_bold"
            android:gravity="center"
            android:includeFontPadding="false"
            android:lineSpacingExtra="2dp"
            android:text="@string/auth_create_account"
            android:textColor="@color/brand_primary"
            android:textSize="28sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:fontFamily="@font/inter_medium"
            android:gravity="center"
            android:lineSpacingExtra="3dp"
            android:text="@string/auth_sign_up_desc"
            android:textColor="@color/screen_subtitle"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:background="@drawable/bg_login_card"
            android:elevation="8dp"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingTop="24dp"
            android:paddingEnd="22dp"
            android:paddingBottom="20dp">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/auth_full_name"
                app:boxBackgroundColor="@color/white"
                app:boxCornerRadiusBottomEnd="18dp"
                app:boxCornerRadiusBottomStart="18dp"
                app:boxCornerRadiusTopEnd="18dp"
                app:boxCornerRadiusTopStart="18dp"
                app:boxStrokeColor="@color/auth_input_stroke"
                app:boxStrokeErrorColor="@color/status_red"
                app:boxStrokeWidth="1.5dp"
                app:boxStrokeWidthFocused="2dp"
                app:hintTextColor="@color/screen_subtitle">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtName"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:fontFamily="@font/inter_medium"
                    android:inputType="textPersonName"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="@color/brand_primary"
                    android:textColorHint="@color/screen_subtitle"
                    android:textSize="14sp"
                    tools:text="Cashy" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:hint="@string/auth_email"
                app:boxBackgroundColor="@color/white"
                app:boxCornerRadiusBottomEnd="18dp"
                app:boxCornerRadiusBottomStart="18dp"
                app:boxCornerRadiusTopEnd="18dp"
                app:boxCornerRadiusTopStart="18dp"
                app:boxStrokeColor="@color/auth_input_stroke"
                app:boxStrokeErrorColor="@color/status_red"
                app:boxStrokeWidth="1.5dp"
                app:boxStrokeWidthFocused="2dp"
                app:hintTextColor="@color/screen_subtitle">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtEmail"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:fontFamily="@font/inter_medium"
                    android:inputType="textEmailAddress"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="@color/brand_primary"
                    android:textColorHint="@color/screen_subtitle"
                    android:textSize="14sp"
                    tools:text="cashy@gmail.com" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:hint="@string/auth_password"
                app:boxBackgroundColor="@color/white"
                app:boxCornerRadiusBottomEnd="18dp"
                app:boxCornerRadiusBottomStart="18dp"
                app:boxCornerRadiusTopEnd="18dp"
                app:boxCornerRadiusTopStart="18dp"
                app:boxStrokeColor="@color/auth_input_stroke"
                app:boxStrokeErrorColor="@color/status_red"
                app:boxStrokeWidth="1.5dp"
                app:boxStrokeWidthFocused="2dp"
                app:hintTextColor="@color/screen_subtitle"
                app:passwordToggleEnabled="true"
                app:passwordToggleTint="@color/screen_subtitle">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtPassword"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:fontFamily="@font/inter_medium"
                    android:inputType="textPassword"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="@color/brand_primary"
                    android:textColorHint="@color/screen_subtitle"
                    android:textSize="14sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:hint="@string/auth_confirm_password"
                app:boxBackgroundColor="@color/white"
                app:boxCornerRadiusBottomEnd="18dp"
                app:boxCornerRadiusBottomStart="18dp"
                app:boxCornerRadiusTopEnd="18dp"
                app:boxCornerRadiusTopStart="18dp"
                app:boxStrokeColor="@color/auth_input_stroke"
                app:boxStrokeErrorColor="@color/status_red"
                app:boxStrokeWidth="1.5dp"
                app:boxStrokeWidthFocused="2dp"
                app:hintTextColor="@color/screen_subtitle"
                app:passwordToggleEnabled="true"
                app:passwordToggleTint="@color/screen_subtitle">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtConfirmPassword"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:fontFamily="@font/inter_medium"
                    android:inputType="textPassword"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="@color/brand_primary"
                    android:textColorHint="@color/screen_subtitle"
                    android:textSize="14sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRegister"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/inter_bold"
                android:text="@string/auth_register"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
                app:backgroundTint="@color/brand_primary"
                app:cornerRadius="28dp"
                app:elevation="3dp" />

            <TextView
                android:id="@+id/tvHasAccount"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/inter_bold"
                android:gravity="center"
                android:text="@string/auth_already_have_account"
                android:textColor="@color/brand_primary"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
