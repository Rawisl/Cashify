<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F8"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbarSocialNewsfeed"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#1A237E"
            android:paddingStart="6dp"
            android:paddingEnd="12dp"
            app:navigationIcon="@drawable/ic_menu_padded"
            app:navigationIconTint="@color/white">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/community"
                android:textAppearance="@style/ToolbarTitleFont"
                android:textColor="@color/white" />

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="end|center_vertical"
                android:background="@drawable/bg_mini_pill"
                android:padding="9dp"
                android:scaleType="center"
                android:src="@drawable/ic_notification_regular"
                app:tint="@color/white" />
        </com.google.android.material.appbar.MaterialToolbar>

        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipeRefreshNewsfeed"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.core.widget.NestedScrollView
                android:id="@+id/scrollNewsfeed"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingBottom="32dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="20dp"
                    android:paddingTop="18dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="28dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/outfit_bold"
                        android:text="@string/community_corner"
                        android:textColor="#1A237E"
                        android:textSize="24sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/inter_regular"
                        android:lineSpacingExtra="3dp"
                        android:text="@string/wtfisthat"
                        android:textColor="#607D8B"
                        android:textSize="13sp" />

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardCreatePostPrompt"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="22dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardBackgroundColor="@android:color/transparent"
                        app:cardCornerRadius="0dp"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_social_editorial_card"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:padding="14dp">

                            <com.example.cashify.ui.common.AvatarImageView
                                android:id="@+id/imgCreatePromptAvatar"
                                android:layout_width="46dp"
                                android:layout_height="46dp"
                                android:scaleType="centerCrop"
                                android:src="@drawable/bg_default_avatar_pastel" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/inter_bold"
                                    android:maxLines="2"
                                    android:text="@string/what_is_your_thought"
                                    android:textColor="#1A237E"
                                    android:textSize="15sp" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="3dp"
                                    android:fontFamily="@font/inter_regular"
                                    android:maxLines="2"
                                    android:text="@string/new_attachment"
                                    android:textColor="#607D8B"
                                    android:textSize="12sp" />
                            </LinearLayout>

                            <ImageView
                                android:id="@+id/btnCreatePostPrompt"
                                android:layout_width="42dp"
                                android:layout_height="42dp"
                                android:layout_marginStart="10dp"
                                android:background="@drawable/bg_social_bottom_cta"
                                android:contentDescription="@string/create_post"
                                android:padding="10dp"
                                android:src="@drawable/ic_add_bold"
                                app:tint="@color/white" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="236dp"
                        android:layout_marginTop="22dp"
                        android:background="@drawable/bg_social_insight_navy"
                        android:elevation="3dp"
                        android:padding="18dp">

                        <View
                            android:layout_width="126dp"
                            android:layout_height="126dp"
                            android:layout_gravity="top|end"
                            android:layout_marginTop="-34dp"
                            android:layout_marginEnd="-34dp"
                            android:background="@drawable/bg_milestone_glow" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="bottom"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="30dp"
                                android:background="@drawable/bg_social_peach_chip"
                                android:fontFamily="@font/inter_bold"
                                android:gravity="center"
                                android:paddingStart="13dp"
                                android:paddingEnd="13dp"
                                android:text="@string/today_suggestion"
                                android:textColor="#1A237E"
                                android:textSize="10sp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:fontFamily="@font/outfit_bold"
                                android:lineSpacingExtra="1dp"
                                android:text="@string/a_partner"
                                android:textColor="@color/white"
                                android:textSize="22sp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:fontFamily="@font/inter_regular"
                                android:lineSpacingExtra="3dp"
                                android:text="@string/wtfisthisshit"
                                android:textColor="#F5E9D8"
                                android:textSize="13sp" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="16dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="36dp"
                                    android:layout_marginEnd="8dp"
                                    android:layout_weight="1"
                                    android:background="@drawable/bg_social_warm_chip"
                                    android:fontFamily="@font/inter_bold"
                                    android:gravity="center"
                                    android:text="@string/new_post"
                                    android:textColor="#1A237E"
                                    android:textSize="12sp" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="36dp"
                                    android:layout_marginStart="8dp"
                                    android:layout_weight="1"
                                    android:background="@drawable/bg_social_warm_chip"
                                    android:fontFamily="@font/inter_bold"
                                    android:gravity="center"
                                    android:text="@string/discussing"
                                    android:textColor="#1A237E"
                                    android:textSize="12sp" />
                            </LinearLayout>
                        </LinearLayout>
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/outfit_bold"
                                android:text="@string/for_you"
                                android:textColor="#1A237E"
                                android:textSize="21sp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:fontFamily="@font/inter_regular"
                                android:text="@string/newest_finance_post"
                                android:textColor="#607D8B"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="34dp"
                            android:background="@drawable/bg_social_warm_chip"
                            android:fontFamily="@font/inter_bold"
                            android:gravity="center"
                            android:paddingStart="13dp"
                            android:paddingEnd="13dp"
                            android:text="@string/public_state"
                            android:textColor="#1A237E"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/progressNewsfeed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="24dp"
                        android:indeterminateTint="#1A237E"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/layoutNewsfeedEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:background="@drawable/bg_social_editorial_card"
                        android:fontFamily="@font/inter_regular"
                        android:gravity="center"
                        android:lineSpacingExtra="3dp"
                        android:padding="24dp"
                        android:text="@string/no_post_post_one"
                        android:textColor="#607D8B"
                        android:textSize="14sp"
                        android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/layoutNoFriendsEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:background="@drawable/bg_social_editorial_card"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="32dp"
                        android:visibility="gone">

                        <ImageView
                            android:layout_width="120dp"
                            android:layout_height="120dp"
                            android:src="@drawable/cashy_mascot"
                            android:alpha="0.6" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="24dp"
                            android:fontFamily="@font/outfit_bold"
                            android:gravity="center"
                            android:text="@string/you_have_no_friend"
                            android:textColor="#1A237E"
                            android:textSize="20sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:fontFamily="@font/inter_regular"
                            android:gravity="center"
                            android:lineSpacingExtra="3dp"
                            android:text="@string/to_sidebar_to_connect"
                            android:textColor="#607D8B"
                            android:textSize="14sp" />

                        <Button
                            android:id="@+id/btnFindFriends"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:background="@drawable/bg_btn_primary"
                            android:fontFamily="@font/inter_bold"
                            android:paddingStart="24dp"
                            android:paddingTop="12dp"
                            android:paddingEnd="24dp"
                            android:paddingBottom="12dp"
                            android:text="@string/find_friend_rn"
                            android:textColor="@color/white"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/layoutNewsfeedError"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:background="@drawable/bg_social_editorial_card"
                        android:clickable="true"
                        android:focusable="true"
                        android:fontFamily="@font/inter_bold"
                        android:gravity="center"
                        android:lineSpacingExtra="3dp"
                        android:padding="22dp"
                        android:text="@string/cannot_load_feed_plz_try_again"
                        android:textColor="#1A237E"
                        android:textSize="14sp"
                        android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/layoutNewsfeedSkeleton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <com.example.cashify.ui.common.FeedSkeletonCardView
                            android:layout_width="match_parent"
                            android:layout_height="382dp"
                            android:layout_marginBottom="10dp" />

                        <com.example.cashify.ui.common.FeedSkeletonCardView
                            android:layout_width="match_parent"
                            android:layout_height="382dp"
                            android:layout_marginBottom="10dp" />

                        <com.example.cashify.ui.common.FeedSkeletonCardView
                            android:layout_width="match_parent"
                            android:layout_height="382dp"
                            android:layout_marginBottom="10dp" />

                        <com.example.cashify.ui.common.FeedSkeletonCardView
                            android:layout_width="match_parent"
                            android:layout_height="382dp"
                            android:layout_marginBottom="10dp" />
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvNewsfeed"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:nestedScrollingEnabled="false" />

                    <ProgressBar
                        android:id="@+id/progressNewsfeedMore"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="10dp"
                        android:indeterminateTint="#1A237E"
                        android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/layoutNewsfeedEnd"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:layout_marginBottom="8dp"
                        android:background="@drawable/bg_social_editorial_card"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingStart="20dp"
                        android:paddingTop="18dp"
                        android:paddingEnd="20dp"
                        android:paddingBottom="18dp"
                        android:visibility="gone">

                        <ImageView
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:background="@drawable/bg_social_warm_chip"
                            android:padding="8dp"
                            android:src="@drawable/ic_cozy_coin"
                            app:tint="#1A237E" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:fontFamily="@font/inter_bold"
                            android:gravity="center"
                            android:text="@string/no_more_feed"
                            android:textColor="#1A237E"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="@font/inter_regular"
                            android:gravity="center"
                            android:text="@string/plz_comeback_later"
                            android:textColor="#607D8B"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.core.widget.NestedScrollView>
        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabCreatePost"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="64dp"
        android:contentDescription="@string/create_post"
        android:src="@drawable/ic_add_bold"
        android:visibility="gone"
        app:backgroundTint="#1A237E"
        app:borderWidth="0dp"
        app:elevation="8dp"
        app:fabCustomSize="48dp"
        app:maxImageSize="22dp"
        app:tint="@color/white" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
