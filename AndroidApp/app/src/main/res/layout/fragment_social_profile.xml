<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <!-- HEADER: Toolbar với nút hamburger mở sidebar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarProfile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbarSocialProfile"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@drawable/bg_toolbar_rounded"
            app:navigationIcon="@drawable/ic_menu_padded"
            app:navigationIconTint="@color/white">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Hồ sơ"
                android:textColor="@color/white"
                android:textAppearance="@style/ToolbarTitleFont" />

        </com.google.android.material.appbar.MaterialToolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- CONTENT: NestedScrollView bao toàn bộ nội dung -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="100dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- NỬA TRÊN: Profile Header Card                       -->
            <!-- ═══════════════════════════════════════════════════ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:gravity="center_horizontal">

                    <!-- Avatar -->
                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/imgAvatar"
                        android:layout_width="96dp"
                        android:layout_height="96dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_profile_regular"
                        app:shapeAppearanceOverlay="@style/CircleImageView"
                        app:strokeColor="@color/brand_primary"
                        app:strokeWidth="3dp" />

                    <!-- Tên hiển thị -->
                    <TextView
                        android:id="@+id/tvDisplayName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Tên người dùng"
                        android:textColor="@color/item_title"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/outfit_bold" />

                    <!-- Username / handle -->
                    <TextView
                        android:id="@+id/tvUsername"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="user"
                        android:textColor="@color/item_description"
                        android:textSize="14sp" />

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="16dp"
                        android:background="@color/cardview_divider" />

                    <!-- Stats Row: Bạn bè | Cúp chiến tích -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <!-- Stat: Bạn bè -->
                        <LinearLayout
                            android:id="@+id/layoutFriends"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:src="@drawable/ic_profile_regular"
                                app:tint="@color/brand_primary" />

                            <TextView
                                android:id="@+id/tvFriendCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="0"
                                android:textColor="@color/item_title"
                                android:textSize="22sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Bạn bè"
                                android:textColor="@color/item_description"
                                android:textSize="12sp" />

                        </LinearLayout>

                        <!-- Vertical divider -->
                        <View
                            android:layout_width="1dp"
                            android:layout_height="48dp"
                            android:background="@color/cardview_divider" />

                        <!-- Stat: Cúp chiến tích -->
                        <LinearLayout
                            android:id="@+id/layoutTrophies"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:src="@drawable/ic_home_regular"
                                app:tint="@color/accent_gold" />

                            <TextView
                                android:id="@+id/tvTrophyCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="0"
                                android:textColor="@color/item_title"
                                android:textSize="22sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Cúp chiến tích"
                                android:textColor="@color/item_description"
                                android:textSize="12sp" />

                        </LinearLayout>

                    </LinearLayout>
                    <!-- end Stats Row -->

                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <!-- end Profile Header Card -->

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- NỬA DƯỚI: Section header + RecyclerView bài viết    -->
            <!-- ═══════════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="8dp">

                <!-- Section title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bài viết của tôi"
                    style="@style/screen_title" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="Hoạt động &amp; Cột mốc tự động"
                    style="@style/screen_subtitle" />

            </LinearLayout>

            <!--
                RecyclerView bài viết của chính user.
                Dùng wrap_content + nestedScrollingEnabled=false
                để scroll cùng với NestedScrollView cha.
            -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMyPosts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never" />

            <!-- Empty state (ẩn khi có dữ liệu) -->
            <LinearLayout
                android:id="@+id/layoutEmptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="40dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_home_regular"
                    android:alpha="0.3"
                    app:tint="@color/item_description" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Chưa có bài viết nào"
                    android:textColor="@color/item_description"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Các bài viết và cột mốc của bạn sẽ xuất hiện ở đây"
                    android:textColor="@color/item_description"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:paddingHorizontal="32dp" />

            </LinearLayout>
            <!-- end empty state -->

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>