<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:left="4dp"
        android:top="5dp">
        <shape>
            <solid android:color="#E8C8D4" />
            <corners android:radius="24dp" />
        </shape>
    </item>
    <item
        android:right="4dp"
        android:bottom="5dp">
        <shape>
            <gradient
                android:angle="135"
                android:endColor="#FFEAF1"
                android:startColor="#FFF7FA"
                android:type="linear" />
            <stroke
                android:width="1.5dp"
                android:color="#EF5350" />
            <corners android:radius="24dp" />
        </shape>
    </item>
</layer-list>
